---
import { getComicPageSrc } from "../lib/comic-url";

interface Props {
  title: string;
  href: string;
  artistName: string;
  /** First page image filename — used as the cover thumbnail. */
  coverFile: string;
  pageCount: number;
}

const { title, href, artistName, coverFile, pageCount } = Astro.props;
---

<a class="comic-card" href={href}>
  <div class="comic-card__cover">
    <img
      class="comic-card__img"
      src={getComicPageSrc(coverFile)}
      alt={`${artistName} — ${title}`}
      loading="lazy"
      decoding="async"
    />
    {pageCount > 1 && (
      <span class="comic-card__pages">{pageCount} pages</span>
    )}
  </div>
  <div class="comic-card__body">
    <p class="comic-card__artist">{artistName}</p>
    <p class="comic-card__title">{title}</p>
  </div>
</a>

<style>
  .comic-card {
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border: var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-hard);
    text-decoration: none;
    color: var(--color-ink);
    overflow: hidden;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .comic-card:hover {
    text-decoration: none;
    transform: translate(-3px, -3px) rotate(-0.6deg);
    box-shadow: 9px 9px 0 var(--color-ink);
  }
  .comic-card:focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 3px;
  }
  /* Comic art varies (wide strips, tall pages). Show a square crop from the
     top so the title panel reads in the grid. */
  .comic-card__cover {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-yellow);
    border-bottom: var(--border);
    overflow: hidden;
  }
  .comic-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .comic-card:hover .comic-card__img {
    transform: scale(1.04);
  }
  .comic-card__pages {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    color: var(--color-ink);
    background: var(--color-paper);
    border: var(--border-thin);
    border-radius: 999px;
    padding: 0.25em 0.6em;
  }
  .comic-card__body {
    padding: 0.85rem 1rem 1.05rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .comic-card__artist {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.1rem;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .comic-card:hover .comic-card__artist {
    color: var(--color-pink-deep);
  }
  .comic-card__title {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.25;
    color: var(--color-muted);
  }
</style>
