---
import { getComicPageSrc } from "../lib/comic-url";

interface Props {
  title: string;
  href: string;
  artistName: string;
  /** First page image filename — used as the cover thumbnail. */
  coverFile: string;
  pageCount: number;
}

const { title, href, artistName, coverFile, pageCount } = Astro.props;
---

<a class="comic-card" href={href}>
  <div class="comic-card__cover">
    <img
      class="comic-card__img"
      src={getComicPageSrc(coverFile)}
      alt={`${artistName} — ${title}`}
      loading="lazy"
      decoding="async"
    />
    {pageCount > 1 && (
      <span class="comic-card__pages">{pageCount} pages</span>
    )}
  </div>
  <div class="comic-card__body">
    <p class="comic-card__artist">{artistName}</p>
    <p class="comic-card__title">{title}</p>
  </div>
</a>

<style>
  /* Clean page tile, type below, no box. */
  .comic-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: transparent;
    text-decoration: none;
    color: var(--color-ink);
  }
  .comic-card:hover {
    text-decoration: none;
  }
  .comic-card:focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 4px;
    border-radius: var(--radius);
  }
  /* Comic art varies (wide strips, tall pages). Show a square crop from the
     top so the title panel reads in the grid. Pages are mostly white scans,
     so the tile stays white in both themes. */
  .comic-card__cover {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #fff;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .comic-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top center;
    display: block;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .comic-card:hover .comic-card__img {
    transform: scale(1.03);
  }
  .comic-card__pages {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    color: #f4f2ee;
    background: rgba(11, 11, 13, 0.72);
    border: 1px solid rgba(244, 242, 238, 0.25);
    border-radius: 999px;
    padding: 0.35em 0.75em;
  }
  .comic-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-inline: 0.15rem;
  }
  .comic-card__artist {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.2rem;
    line-height: 1;
    letter-spacing: 0.015em;
    transition: color 0.12s ease;
  }
  .comic-card:hover .comic-card__artist {
    color: var(--accent-text, var(--color-pink-deep));
  }
  .comic-card__title {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-muted);
  }
</style>
