---
import SeriesBadge from "./SeriesBadge.astro";
import { getLocalThumb } from "../lib/thumbs";

interface Props {
  title: string;
  href: string;
  artistName: string;
  seriesTitle: string;
  seriesSlug: string;
  recordedAt: Date;
  provider: "youtube" | "vimeo" | "dailymotion" | "flash" | string;
  providerId: string;
  thumbnailSlug?: string;
  /** Show the series badge — only useful in mixed-series contexts
      (video page related sections, artist pages). */
  showBadge?: boolean;
}

const {
  title,
  href,
  artistName,
  seriesTitle,
  seriesSlug,
  recordedAt,
  provider,
  providerId,
  thumbnailSlug,
  showBadge = false,
} = Astro.props;

const year = new Date(recordedAt).getUTCFullYear();
// Thumbnail priority: local archive image keyed by the original video slug,
// then YouTube's CDN, then a styled placeholder.
const slug = href.split("/").filter(Boolean).pop() ?? "";
const thumb =
  getLocalThumb(thumbnailSlug ?? slug) ??
  (provider === "youtube"
    ? `https://i.ytimg.com/vi/${providerId}/hqdefault.jpg`
    : null);
---

<a class="card" href={href} data-series={seriesSlug}>
  <div class="card__thumb">
    {
      thumb ? (
        <img
          class="card__img"
          src={thumb}
          alt=""
          loading="lazy"
          decoding="async"
          width="640"
          height="360"
        />
      ) : (
        <div class="card__placeholder" aria-hidden="true">
          <svg
            class="card__placeholder-mark"
            viewBox="0 0 64 40"
            focusable="false"
          >
            <g
              stroke="#F4F2EE"
              stroke-width="3"
              stroke-linejoin="round"
              stroke-linecap="round"
            >
              <rect x="10" y="6" width="44" height="14" rx="6" fill="var(--accent, var(--color-pink))" />
              <rect x="8" y="17" width="48" height="13" rx="5" fill="var(--accent, var(--color-pink))" />
              <line x1="32" y1="19" x2="32" y2="28" />
              <rect x="6" y="13" width="10" height="17" rx="4" fill="var(--accent, var(--color-pink))" />
              <rect x="48" y="13" width="10" height="17" rx="4" fill="var(--accent, var(--color-pink))" />
            </g>
          </svg>
          <span class="card__placeholder-label">{provider}</span>
        </div>
      )
    }
    {showBadge && (
      <span class="card__badge">
        <SeriesBadge title={seriesTitle} slug={seriesSlug} as="span" />
      </span>
    )}
  </div>

  <div class="card__body">
    <p class="card__artist">{artistName}</p>
    <p class="card__title">{title}</p>
    <p class="meta-line card__year">{year}</p>
  </div>
</a>

<style>
  /* A still from the archive: clean image tile, type below, no box. */
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
    background: transparent;
    text-decoration: none;
    color: var(--color-ink);
  }
  .card:hover {
    text-decoration: none;
  }
  .card:focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 4px;
    border-radius: var(--radius);
  }

  .card__thumb {
    position: relative;
    aspect-ratio: 16 / 9;
    background: #101013;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  /* Footage sits slightly dimmed until you reach for it. */
  .card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.85) brightness(0.92);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.3s ease;
  }
  .card:hover .card__img {
    transform: scale(1.04);
    filter: saturate(1.05) brightness(1);
  }

  .card__placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 0.7rem;
    background: #101013;
  }
  .card__placeholder-mark {
    width: 34%;
    max-width: 4.5rem;
    height: auto;
  }
  .card__placeholder-label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.14em;
    color: rgba(244, 242, 238, 0.7);
  }

  .card__badge {
    position: absolute;
    left: 0.7rem;
    bottom: 0.7rem;
    z-index: 2;
  }

  .card__body {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding-inline: 0.15rem;
  }
  .card__artist {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.35rem;
    line-height: 1;
    letter-spacing: 0.015em;
    color: var(--color-ink);
    transition: color 0.12s ease;
  }
  .card:hover .card__artist {
    color: var(--accent-text, var(--color-pink-deep));
  }
  .card__title {
    margin: 0;
    font-size: 1rem;
    line-height: 1.3;
    color: var(--color-muted);
  }
  .card__year {
    margin: 0.2rem 0 0;
  }
</style>
