---
import { getAlbumCover } from "../lib/album-covers";

interface Props {
  title: string;
  href: string;
  /** Album slug — the cover-art key (distinct from the URL). */
  slug: string;
  artistName: string;
  releasedAt: Date;
  downloads?: number;
}

const { title, href, slug, artistName, releasedAt, downloads = 0 } = Astro.props;
const year = new Date(releasedAt).getUTCFullYear();
const cover = getAlbumCover(slug);
const downloadsLabel = new Intl.NumberFormat("en-US", {
  notation: "compact",
  maximumFractionDigits: 1,
}).format(downloads);
---

<a class="album-card" href={href}>
  <div class="album-card__cover">
    {
      cover ? (
        <img
          class="album-card__img"
          src={cover}
          alt={`${artistName} — ${title} cover`}
          loading="lazy"
          decoding="async"
          width="500"
          height="500"
        />
      ) : (
        <div class="album-card__placeholder" aria-hidden="true">
          <span class="album-card__placeholder-mark">♪</span>
        </div>
      )
    }
    {downloads > 0 && (
      <span class="album-card__downloads">{downloadsLabel} ⤓</span>
    )}
  </div>
  <div class="album-card__body">
    <p class="album-card__artist">{artistName}</p>
    <p class="album-card__title">{title}</p>
    <p class="meta-line album-card__year">{year}</p>
  </div>
</a>

<style>
  /* A record sleeve on a shelf: clean square tile, type below, no box. */
  .album-card {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    background: transparent;
    text-decoration: none;
    color: var(--color-ink);
  }
  .album-card:hover {
    text-decoration: none;
  }
  .album-card:focus-visible {
    outline: 3px solid var(--color-yellow);
    outline-offset: 4px;
    border-radius: var(--radius);
  }
  .album-card__cover {
    position: relative;
    aspect-ratio: 1 / 1;
    background: #101013;
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    overflow: hidden;
  }
  .album-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9) brightness(0.94);
    transition:
      transform 0.3s cubic-bezier(0.22, 1, 0.36, 1),
      filter 0.3s ease;
  }
  .album-card:hover .album-card__img {
    transform: scale(1.04);
    filter: saturate(1.02) brightness(1);
  }
  .album-card__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    background: #101013;
  }
  .album-card__placeholder-mark {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-blue);
  }
  .album-card__downloads {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    color: #f4f2ee;
    background: rgba(11, 11, 13, 0.72);
    border: 1px solid rgba(244, 242, 238, 0.25);
    border-radius: 999px;
    padding: 0.35em 0.75em;
  }
  .album-card__body {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
    padding-inline: 0.15rem;
  }
  .album-card__artist {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.2rem;
    line-height: 1;
    letter-spacing: 0.015em;
    transition: color 0.12s ease;
  }
  .album-card:hover .album-card__artist {
    color: var(--color-blue);
  }
  .album-card__title {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.3;
    color: var(--color-muted);
  }
  .album-card__year {
    margin: 0.2rem 0 0;
  }
</style>
