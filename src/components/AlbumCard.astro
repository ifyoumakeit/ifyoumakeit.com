---
import { getAlbumCover } from "../lib/album-covers";

interface Props {
  title: string;
  href: string;
  /** Album slug — the cover-art key (distinct from the URL). */
  slug: string;
  artistName: string;
  releasedAt: Date;
  downloads?: number;
}

const { title, href, slug, artistName, releasedAt, downloads = 0 } = Astro.props;
const year = new Date(releasedAt).getUTCFullYear();
const cover = getAlbumCover(slug);
const downloadsLabel = new Intl.NumberFormat("en-US", {
  notation: "compact",
  maximumFractionDigits: 1,
}).format(downloads);
---

<a class="album-card" href={href}>
  <div class="album-card__cover">
    {
      cover ? (
        <img
          class="album-card__img"
          src={cover}
          alt={`${artistName} — ${title} cover`}
          loading="lazy"
          decoding="async"
          width="500"
          height="500"
        />
      ) : (
        <div class="album-card__placeholder" aria-hidden="true">
          <span class="album-card__placeholder-mark">♪</span>
        </div>
      )
    }
    {downloads > 0 && (
      <span class="album-card__downloads">{downloadsLabel} ⤓</span>
    )}
  </div>
  <div class="album-card__body">
    <p class="album-card__artist">{artistName}</p>
    <p class="album-card__title">{title}</p>
    <p class="meta-line album-card__year">{year}</p>
  </div>
</a>

<style>
  .album-card {
    display: flex;
    flex-direction: column;
    background: var(--color-paper);
    border: var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-hard);
    text-decoration: none;
    color: var(--color-ink);
    overflow: hidden;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .album-card:hover {
    text-decoration: none;
    transform: translate(-3px, -3px) rotate(-0.6deg);
    box-shadow: 9px 9px 0 var(--color-ink);
  }
  .album-card:focus-visible {
    outline: 3px solid var(--color-blue);
    outline-offset: 3px;
  }
  .album-card__cover {
    position: relative;
    aspect-ratio: 1 / 1;
    background: var(--color-blue);
    border-bottom: var(--border);
    overflow: hidden;
  }
  .album-card__img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.25s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .album-card:hover .album-card__img {
    transform: scale(1.05);
  }
  .album-card__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    background: var(--color-blue);
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0,
      transparent 10px,
      rgba(22, 18, 26, 0.08) 10px,
      rgba(22, 18, 26, 0.08) 20px
    );
  }
  .album-card__placeholder-mark {
    font-family: var(--font-display);
    font-size: 3rem;
    color: var(--color-paper);
    filter: drop-shadow(2px 2px 0 var(--color-ink));
  }
  .album-card__downloads {
    position: absolute;
    right: 0.6rem;
    bottom: 0.6rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    color: var(--color-ink);
    background: var(--color-paper);
    border: var(--border-thin);
    border-radius: 999px;
    padding: 0.25em 0.6em;
  }
  .album-card__body {
    padding: 0.85rem 1rem 1.05rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }
  .album-card__artist {
    margin: 0;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.1rem;
    line-height: 0.95;
    letter-spacing: -0.01em;
  }
  .album-card:hover .album-card__artist {
    color: var(--color-blue);
  }
  .album-card__title {
    margin: 0;
    font-size: 0.95rem;
    line-height: 1.25;
    color: var(--color-muted);
  }
  .album-card__year {
    margin: 0.35rem 0 0;
  }
</style>
