---
interface Props {
  provider: string;
  providerId: string;
  title: string;
  /** Local archive thumbnail (/thumbs/video/{slug}.jpg) if one exists. */
  thumbnail?: string | null;
}

const { provider, providerId, title, thumbnail = null } = Astro.props;

const isYouTube = provider === "youtube";
const isVimeo = provider === "vimeo";
const isDailymotion = provider === "dailymotion";
const isArchival = provider === "flash";
const isPlayable = isYouTube || isVimeo || isDailymotion;
const poster =
  thumbnail ??
  (isYouTube ? `https://i.ytimg.com/vi/${providerId}/maxresdefault.jpg` : null);
---

<div class="embed">
  {
    isPlayable && (
      <button
        class="embed__facade"
        type="button"
        data-provider={provider}
        data-provider-id={providerId}
        data-title={title}
        aria-label={`Play video: ${title}`}
      >
        {poster ? (
          <img
            class="embed__thumb"
            src={poster}
            onerror={
              isYouTube && !thumbnail
                ? `this.onerror=null;this.src='https://i.ytimg.com/vi/${providerId}/hqdefault.jpg'`
                : undefined
            }
            alt=""
            loading="lazy"
            decoding="async"
            width="1280"
            height="720"
          />
        ) : (
          <span class="embed__placeholder" aria-hidden="true">
            <span class="embed__provider">{provider}</span>
          </span>
        )}
        <span class="embed__play" aria-hidden="true">
          <svg viewBox="0 0 68 48" focusable="false">
            <path
              class="embed__play-bg"
              d="M66.5 7.5a8 8 0 0 0-5.6-5.7C56 .5 34 .5 34 .5s-22 0-26.9 1.3A8 8 0 0 0 1.5 7.5C.2 12.4.2 24 .2 24s0 11.6 1.3 16.5a8 8 0 0 0 5.6 5.7C12 47.5 34 47.5 34 47.5s22 0 26.9-1.3a8 8 0 0 0 5.6-5.7C67.8 35.6 67.8 24 67.8 24s0-11.6-1.3-16.5Z"
            />
            <path class="embed__play-tri" d="M27 34.5 45 24 27 13.5Z" />
          </svg>
        </span>
      </button>
    )
  }

  {
    isArchival && (
      <div class="embed__archival">
        {thumbnail && (
          <img
            class="embed__archival-thumb"
            src={thumbnail}
            alt=""
            loading="lazy"
            decoding="async"
          />
        )}
        <svg
          class="embed__archival-mark"
          viewBox="0 0 64 40"
          aria-hidden="true"
        >
          <g
            stroke="var(--color-ink)"
            stroke-width="3"
            stroke-linejoin="round"
            stroke-linecap="round"
          >
            <rect
              x="10"
              y="6"
              width="44"
              height="14"
              rx="6"
              fill="var(--color-pink)"
            />
            <rect
              x="8"
              y="17"
              width="48"
              height="13"
              rx="5"
              fill="var(--color-pink)"
            />
            <line x1="32" y1="19" x2="32" y2="28" />
            <rect
              x="6"
              y="13"
              width="10"
              height="17"
              rx="4"
              fill="var(--color-pink-deep)"
            />
            <rect
              x="48"
              y="13"
              width="10"
              height="17"
              rx="4"
              fill="var(--color-pink-deep)"
            />
          </g>
        </svg>
        <p class="embed__archival-text">
          This one's from the Flash era — archival video not yet migrated.
        </p>
      </div>
    )
  }
</div>

<script>
  // Click-to-play: swap a facade button for its provider iframe on first
  // click. A single delegated listener covers every embed on the page; Astro
  // bundles this module once per page, so no init guard is needed.
  type Provider = "youtube" | "vimeo" | "dailymotion";

  const embedUrl: Record<Provider, (id: string) => string> = {
    youtube: (id) =>
      `https://www.youtube-nocookie.com/embed/${encodeURIComponent(id)}?autoplay=1`,
    vimeo: (id) =>
      `https://player.vimeo.com/video/${encodeURIComponent(id)}?autoplay=1`,
    dailymotion: (id) =>
      `https://www.dailymotion.com/embed/video/${encodeURIComponent(id)}?autoplay=1`,
  };

  document.addEventListener("click", (event) => {
    const facade = (event.target as Element | null)?.closest<HTMLButtonElement>(
      ".embed__facade",
    );
    if (!facade) return;

    const provider = facade.dataset.provider as Provider | undefined;
    const id = facade.dataset.providerId;
    if (!provider || !id || !(provider in embedUrl)) return;

    const iframe = document.createElement("iframe");
    iframe.style.cssText =
      "position:absolute;inset:0;width:100%;height:100%;border:0;display:block";
    iframe.src = embedUrl[provider](id);
    iframe.title = `Video: ${facade.dataset.title || "Untitled"}`;
    iframe.setAttribute("allowfullscreen", "");
    iframe.setAttribute(
      "allow",
      "autoplay; encrypted-media; fullscreen; picture-in-picture",
    );
    iframe.setAttribute("referrerpolicy", "strict-origin-when-cross-origin");
    facade.replaceWith(iframe);
  });
</script>

<style>
  .embed {
    position: relative;
    aspect-ratio: 16 / 9;
    width: 100%;
    background: #000;
    border: var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-hard);
    overflow: hidden;
  }

  /* ---- click-to-play facade ---- */
  .embed__facade {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    padding: 0;
    margin: 0;
    border: 0;
    background: #000;
    cursor: pointer;
    display: block;
    overflow: hidden;
  }
  .embed__thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.2s ease;
  }
  .embed__placeholder {
    position: absolute;
    inset: 0;
    display: grid;
    place-items: center;
    background:
      repeating-linear-gradient(
        -45deg,
        transparent 0,
        transparent 12px,
        color-mix(in srgb, var(--color-ink) 7%, transparent) 12px,
        color-mix(in srgb, var(--color-ink) 7%, transparent) 24px
      ),
      var(--color-panel);
  }
  .embed__provider {
    position: absolute;
    left: 1rem;
    bottom: 1rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(0.8rem, 2.5vw, 1rem);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-ink);
    background: var(--color-paper);
    border: var(--border);
    border-radius: 0;
    padding: 0.45em 0.85em;
  }
  .embed__facade:hover .embed__thumb {
    transform: scale(1.03);
  }

  .embed__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(56px, 14%, 84px);
    height: auto;
    aspect-ratio: 68 / 48;
    display: grid;
    place-items: center;
    filter: drop-shadow(3px 3px 0 rgba(0, 0, 0, 0.55));
    transition: transform 0.12s ease;
  }
  .embed__play svg {
    width: 100%;
    height: 100%;
  }
  .embed__play-bg {
    fill: var(--color-pink);
    stroke: var(--color-ink);
    stroke-width: 3;
  }
  .embed__play-tri {
    fill: var(--on-accent);
  }
  .embed__facade:hover .embed__play {
    transform: translate(-50%, -50%) scale(1.08) rotate(-3deg);
    animation: play-wobble 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  @keyframes play-wobble {
    0% {
      transform: translate(-50%, -50%) scale(1);
    }
    35% {
      transform: translate(-50%, -50%) scale(1.16) rotate(-6deg);
    }
    70% {
      transform: translate(-50%, -50%) scale(1.04) rotate(1deg);
    }
    100% {
      transform: translate(-50%, -50%) scale(1.08) rotate(-3deg);
    }
  }
  .embed__facade:focus-visible {
    outline: 4px solid var(--color-yellow);
    outline-offset: -4px;
  }

  /* ---- archival notice ---- */
  .embed__archival {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    padding: 1.5rem;
    text-align: center;
    background: var(--color-panel);
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0,
      transparent 12px,
      color-mix(in srgb, var(--color-ink) 5%, transparent) 12px,
      color-mix(in srgb, var(--color-ink) 5%, transparent) 24px
    );
  }
  .embed__archival-thumb {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.35;
    filter: grayscale(40%);
  }
  .embed__archival-mark,
  .embed__archival-text {
    position: relative;
    z-index: 1;
  }
  .embed__archival-mark {
    width: clamp(70px, 22%, 120px);
    height: auto;
    filter: drop-shadow(3px 3px 0 var(--color-ink));
  }
  .embed__archival-text {
    margin: 0;
    max-width: 26ch;
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: clamp(0.85rem, 2.4vw, 1.05rem);
    line-height: 1.15;
    color: var(--color-ink);
  }
</style>
