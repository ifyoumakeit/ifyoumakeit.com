---
interface Props {
  title: string;
  slug: string;
  as?: "a" | "span";
}

const { title, slug, as: Tag = "a" } = Astro.props;
const linkProps = Tag === "a" ? { href: `/${slug}/` } : {};
---

<Tag class="series-badge" {...linkProps} data-series={slug}>
  <span class="series-badge__dot" aria-hidden="true"></span>
  {title}
</Tag>

<style>
  .series-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-display);
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.02em;
    line-height: 1;
    color: var(--color-ink);
    background: var(--accent);
    border: var(--border-thin);
    border-radius: 999px;
    padding: 0.5em 0.85em;
    box-shadow: 3px 3px 0 var(--color-ink);
    text-decoration: none;
    transform: rotate(-2deg);
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .series-badge:hover {
    text-decoration: none;
    transform: rotate(-2deg) translate(-1px, -1px);
    box-shadow: 4px 4px 0 var(--color-ink);
  }
  .series-badge__dot {
    width: 0.55em;
    height: 0.55em;
    border-radius: 50%;
    background: var(--color-ink);
    flex: none;
  }
</style>
