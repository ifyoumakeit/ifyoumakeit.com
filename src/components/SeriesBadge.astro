---
interface Props {
  title: string;
  slug: string;
  as?: "a" | "span";
}

const { title, slug, as: Tag = "a" }: Props = Astro.props;
const linkProps = Tag === "a" ? { href: `/${slug}/` } : {};
---

<Tag class="series-badge" {...linkProps} data-series={slug}>
  <span class="series-badge__dot" aria-hidden="true"></span>
  {title}
</Tag>

<style>
  /* Quiet caption pill: translucent dark glass with the series color
     as a dot + text. Fixed-dark so it reads over any thumbnail. */
  .series-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.68rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
    color: #f4f2ee;
    background: rgba(11, 11, 13, 0.72);
    border: 1px solid rgba(244, 242, 238, 0.25);
    border-radius: 999px;
    padding: 0.55em 0.9em;
    text-decoration: none;
    transition: border-color 0.12s ease;
  }
  .series-badge:hover {
    text-decoration: none;
    border-color: var(--accent, var(--color-pink));
  }
  .series-badge__dot {
    width: 0.6em;
    height: 0.6em;
    border-radius: 50%;
    background: var(--accent, var(--color-pink));
    flex: none;
  }
</style>
