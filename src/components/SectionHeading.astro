---
interface Props {
  title: string;
  href?: string;
  count?: number;
}

const { title, href, count } = Astro.props;
---

<div class="section-heading">
  <h2 class="section-heading__title">
    {title}
    {count != null && <span class="section-heading__count">{count}</span>}
  </h2>
  {
    Boolean(href) && (
      <a class="section-heading__link" href={href}>
        See all <span aria-hidden="true">&rarr;</span>
      </a>
    )
  }
</div>

<style>
  .section-heading {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.5rem 1rem;
    margin-block-end: clamp(1rem, 2.5vw, 1.5rem);
  }

  .section-heading__title {
    display: inline-flex;
    align-items: baseline;
    gap: 0.6rem;
    margin: 0;
    line-height: 0.96;
    text-shadow: var(--halo);
  }

  /* Count reads like a film-can index number, not a sticker. */
  .section-heading__count {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.42em;
    line-height: 1;
    letter-spacing: 0.08em;
    color: var(--accent-text, var(--color-pink-deep));
    transform: translateY(-0.15em);
  }

  .section-heading__link {
    flex: none;
    display: inline-flex;
    align-items: center;
    gap: 0.4em;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    line-height: 1;
    color: var(--color-muted);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.12s ease;
  }
  .section-heading__link:hover {
    color: var(--accent-text, var(--color-pink-deep));
    text-decoration: none;
  }
</style>
