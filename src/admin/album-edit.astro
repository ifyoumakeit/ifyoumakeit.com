---
import AdminLayout from "./AdminLayout.astro";
import { db, eq, album } from "../lib/db";
import { getAlbumCover } from "../lib/album-covers";
import { getAlbumUrl } from "../lib/album-url";

const id = Number(Astro.params.id);
const [row] = await db.select().from(album).where(eq(album.id, id));
const cover = row ? getAlbumCover(row.slug) : null;
const liveUrl = row ? getAlbumUrl(row) : null;

// Return to the filtered list view the user came from (restricted to albums).
const rawReturn = Astro.url.searchParams.get("return") ?? "";
const returnTo = rawReturn.startsWith("/admin/albums")
  ? rawReturn
  : "/admin/albums";
---

<AdminLayout title={row ? `Edit: ${row.artist_name} — ${row.title}` : "Not found"}>
  {!row ? (
    <p>No album with id {id}. <a href={returnTo}>Back to albums</a>.</p>
  ) : (
    <form id="edit-form" class="admin-card" data-id={row.id} data-return={returnTo}>
      <div class="head">
        {cover ? (
          <img class="cover" src={cover} alt="" width="96" height="96" />
        ) : (
          <span class="cover cover--none">♪</span>
        )}
        <div>
          <p class="head-artist">{row.artist_name}</p>
          <p class="head-sub">
            {new Date(row.released_at).getUTCFullYear()} ·
            {" "}{row.downloads.toLocaleString()} downloads ·
            {" "}<code>{row.slug}</code>
          </p>
        </div>
      </div>

      <div class="row">
        <label>
          <span>Title</span>
          <input name="title" value={row.title} required />
        </label>
        <label>
          <span>Featuring (members)</span>
          <input name="members" value={row.members ?? ""} placeholder="optional" />
        </label>
      </div>

      <label class="full">
        <span>song.link / album.link smart link</span>
        <input
          name="songlink_url"
          type="url"
          value={row.songlink_url ?? ""}
          placeholder="https://album.link/…  (one link to every stream/buy service)"
        />
      </label>

      <label class="full">
        <span>Where to buy (fallback)</span>
        <input name="purchase_url" type="url" value={row.purchase_url ?? ""} placeholder="optional" />
      </label>

      <label class="full">
        <span>Description (Markdown)</span>
        <textarea name="description" rows="6">{row.description ?? ""}</textarea>
      </label>

      <div class="row checks">
        <label class="check">
          <input type="checkbox" name="publish" checked={row.publish === 1} />
          <span>Published</span>
        </label>
      </div>

      <div class="actions">
        <button type="submit" class="btn">Save changes</button>
        <a class="btn ghost" href={returnTo}>Cancel</a>
        {liveUrl && <a class="btn ghost" href={liveUrl} target="_blank">View on site ↗</a>}
      </div>
      <p class="hint">
        Saving writes <code>db/data/albums.json</code> and reloads the dev server.
        Tip: <code>node scripts/build-songlinks.mjs</code> can auto-fill song.link
        from a seed URL.
      </p>
    </form>
  )}

  <div class="admin-toast" id="toast"></div>

  <script>
    const form = document.getElementById("edit-form");
    const toast = (msg, isErr = false) => {
      const t = document.getElementById("toast");
      t.textContent = msg;
      t.classList.toggle("err", isErr);
      t.classList.add("show");
      if (!isErr) return;
      window.setTimeout(() => t.classList.remove("show"), 2500);
    };
    if (form) {
      form.addEventListener("submit", async (e) => {
        e.preventDefault();
        const id = form.dataset.id;
        const fd = new FormData(form);
        const patch = {
          title: fd.get("title"),
          members: fd.get("members"),
          songlink_url: fd.get("songlink_url"),
          purchase_url: fd.get("purchase_url"),
          description: fd.get("description"),
          publish: fd.get("publish") ? 1 : 0,
        };
        const btn = form.querySelector('button[type="submit"]');
        btn.disabled = true;
        try {
          const res = await fetch(`/admin/api/album/${id}`, {
            method: "PUT",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(patch),
          });
          const json = await res.json();
          if (!json.ok) throw new Error(json.error || "save failed");
          toast("Saved. Returning to list…");
          window.setTimeout(() => (window.location.href = form.dataset.return || "/admin/albums"), 600);
        } catch (err) {
          toast(String(err.message || err), true);
          btn.disabled = false;
        }
      });
    }
  </script>

  <style>
    form {
      display: flex;
      flex-direction: column;
      gap: 1rem;
      max-width: 760px;
    }
    .head {
      display: flex;
      align-items: center;
      gap: 1rem;
    }
    .cover {
      width: 96px;
      height: 96px;
      object-fit: cover;
      border: var(--border-thin);
      border-radius: var(--radius);
      flex: none;
    }
    .cover--none {
      display: grid;
      place-content: center;
      background: var(--color-blue);
      color: var(--color-paper);
      font-size: 2rem;
    }
    .head-artist {
      margin: 0;
      font-family: var(--font-display);
      font-size: 1.4rem;
      text-transform: uppercase;
    }
    .head-sub {
      margin: 0.2rem 0 0;
      font-size: 0.8rem;
      color: var(--color-muted);
    }
    .head-sub code {
      font-family: var(--font-mono);
    }
    .row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1rem;
    }
    label {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    label > span {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--color-muted);
    }
    input,
    textarea {
      font-family: var(--font-body);
      font-size: 0.95rem;
      padding: 0.5rem 0.6rem;
      border: var(--border-thin);
      border-radius: var(--radius);
      background: #fff;
    }
    textarea {
      font-family: var(--font-mono);
      font-size: 0.82rem;
      resize: vertical;
    }
    .checks {
      grid-template-columns: auto;
      justify-content: start;
    }
    .check {
      flex-direction: row;
      align-items: center;
      gap: 0.5rem;
    }
    .check span {
      font-size: 0.9rem;
      text-transform: none;
      color: var(--color-ink);
    }
    .actions {
      display: flex;
      gap: 0.75rem;
      flex-wrap: wrap;
    }
    .btn.ghost {
      background: transparent;
    }
    .hint {
      font-size: 0.78rem;
      color: var(--color-muted);
      margin: 0;
    }
    .hint code {
      font-family: var(--font-mono);
      color: var(--color-ink);
    }
    @media (max-width: 620px) {
      .row {
        grid-template-columns: 1fr;
      }
    }
  </style>
</AdminLayout>
