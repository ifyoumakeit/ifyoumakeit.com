---
import AdminLayout from "./AdminLayout.astro";
import { db, album } from "../lib/db";
import { getAlbumCover } from "../lib/album-covers";

const albums = (await db.select().from(album)).sort(
  (a, b) => new Date(b.released_at).getTime() - new Date(a.released_at).getTime(),
);

const withLink = albums.filter((a) => a.songlink_url).length;
const missingLink = albums.length - withLink;
---

<AdminLayout title="Albums">
  <p class="lede">
    {albums.length} albums · <strong>{withLink}</strong> with a song.link ·
    <strong>{missingLink}</strong> still missing one. Edits write
    <code>db/data/albums.json</code>.
  </p>

  <div class="filters admin-card">
    <input id="f-search" type="search" placeholder="Search artist / album…" />
    <select id="f-link">
      <option value="">song.link: any</option>
      <option value="linked">linked</option>
      <option value="missing">missing</option>
    </select>
    <select id="f-pub">
      <option value="">Published + hidden</option>
      <option value="1">Published only</option>
      <option value="0">Hidden only</option>
    </select>
    <span class="count" id="row-count">{albums.length}</span>
  </div>

  <div class="admin-card table-wrap">
    <table>
      <thead>
        <tr>
          <th></th>
          <th>Artist / album</th>
          <th>Year</th>
          <th>Downloads</th>
          <th>song.link</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        {albums.map((a) => {
          const cover = getAlbumCover(a.slug);
          return (
            <tr
              data-id={a.id}
              data-artist={a.artist_name.toLowerCase()}
              data-title={a.title.toLowerCase()}
              data-year={new Date(a.released_at).getUTCFullYear()}
              data-link={a.songlink_url ? "linked" : "missing"}
              data-publish={a.publish}
              class:list={[{ unpub: a.publish !== 1 }]}
            >
              <td>
                {cover ? (
                  <img class="cover" src={cover} alt="" width="40" height="40" />
                ) : (
                  <span class="cover cover--none">♪</span>
                )}
              </td>
              <td>
                <strong>{a.artist_name}</strong>
                <span class="sub">{a.title}</span>
              </td>
              <td>{new Date(a.released_at).getUTCFullYear()}</td>
              <td>{a.downloads.toLocaleString()}</td>
              <td>
                {a.songlink_url ? (
                  <span class="pill pill--ok">linked</span>
                ) : (
                  <span class="pill">—</span>
                )}
              </td>
              <td><a class="btn ghost edit-link" href={`/admin/albums/${a.id}`}>Edit</a></td>
            </tr>
          );
        })}
      </tbody>
    </table>
    {albums.length === 0 && (
      <p class="empty">
        No albums yet. Run <code>node scripts/import-legacy-albums.mjs path/to/iymi_db.sql</code>.
      </p>
    )}
  </div>

  <script>
    const rows = Array.from(document.querySelectorAll("tbody tr"));
    const els = {
      search: document.getElementById("f-search"),
      link: document.getElementById("f-link"),
      pub: document.getElementById("f-pub"),
      count: document.getElementById("row-count"),
    };

    // Forgiving match: tolerates partial words and a short suffix like a plural
    // "s" (so "kudrows" finds "Kudrow"). Mirrors the videos admin.
    function termHits(term, hay, words) {
      if (hay.includes(term)) return true;
      for (const w of words) {
        if (w.startsWith(term)) return true;
        if (term.startsWith(w) && term.length - w.length <= 2 && w.length >= 3)
          return true;
      }
      return false;
    }
    function applyFilters() {
      const q = els.search.value.trim().toLowerCase();
      const terms = q ? q.split(/\s+/) : [];
      const lk = els.link.value;
      const pub = els.pub.value;
      let shown = 0;
      for (const r of rows) {
        const d = r.dataset;
        const hay = `${d.artist} ${d.title} ${d.year}`;
        const words = hay.split(/\s+/).filter(Boolean);
        const ok =
          terms.every((t) => termHits(t, hay, words)) &&
          (!lk || d.link === lk) &&
          (!pub || d.publish === pub);
        r.hidden = !ok;
        if (ok) shown++;
      }
      els.count.textContent = String(shown);
      syncUrl();
      syncEditLinks();
    }

    // Persist filters in the URL so an edit returns to this exact view.
    function currentQuery() {
      const params = new URLSearchParams();
      const v = els.search.value.trim();
      if (v) params.set("q", v);
      if (els.link.value) params.set("link", els.link.value);
      if (els.pub.value) params.set("pub", els.pub.value);
      const s = params.toString();
      return s ? "?" + s : "";
    }
    function syncUrl() {
      history.replaceState(null, "", "/admin/albums" + currentQuery());
    }
    function syncEditLinks() {
      const ret = encodeURIComponent("/admin/albums" + currentQuery());
      for (const a of document.querySelectorAll("a.edit-link")) {
        const id = a.closest("tr").dataset.id;
        a.href = `/admin/albums/${id}?return=${ret}`;
      }
    }

    Object.values(els).forEach((el) => {
      if (el && el.tagName !== "SPAN") el.addEventListener("input", applyFilters);
    });

    const init = new URLSearchParams(location.search);
    els.search.value = init.get("q") || "";
    els.link.value = init.get("link") || "";
    els.pub.value = init.get("pub") || "";
    applyFilters();
  </script>

  <style>
    .lede {
      color: var(--color-muted);
    }
    .filters {
      display: flex;
      gap: 0.6rem;
      flex-wrap: wrap;
      align-items: center;
      margin-bottom: 1rem;
    }
    .filters input,
    .filters select {
      font-family: var(--font-mono);
      font-size: 0.8rem;
      padding: 0.4rem 0.5rem;
      border: var(--border-thin);
      border-radius: var(--radius);
      background: #fff;
    }
    .filters #f-search {
      flex: 1;
      min-width: 12rem;
    }
    .count {
      font-family: var(--font-display);
      background: var(--color-yellow);
      border: var(--border-thin);
      padding: 0.2em 0.55em;
      border-radius: var(--radius);
    }
    .lede code,
    .empty code {
      font-family: var(--font-mono);
      font-size: 0.85em;
      color: var(--color-ink);
    }
    .table-wrap {
      overflow-x: auto;
      padding: 0;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 0.9rem;
    }
    th,
    td {
      text-align: left;
      padding: 0.55rem 0.8rem;
      border-bottom: var(--border-thin);
      vertical-align: middle;
    }
    th {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.04em;
      color: var(--color-muted);
    }
    tr.unpub {
      opacity: 0.5;
    }
    .cover {
      width: 40px;
      height: 40px;
      object-fit: cover;
      border: var(--border-thin);
      border-radius: 4px;
      display: block;
    }
    .cover--none {
      display: grid;
      place-content: center;
      background: var(--color-blue);
      color: var(--color-paper);
    }
    .sub {
      display: block;
      color: var(--color-muted);
    }
    .pill {
      font-family: var(--font-mono);
      font-size: 0.68rem;
      padding: 0.15em 0.5em;
      border-radius: 999px;
      border: var(--border-thin);
    }
    .pill--ok {
      background: var(--color-yellow);
    }
    .btn.ghost {
      background: transparent;
      padding: 0.3rem 0.7rem;
    }
    .empty {
      padding: 1rem;
      color: var(--color-muted);
    }
  </style>
</AdminLayout>
