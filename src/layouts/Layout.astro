---
import "@fontsource/archivo-black";
import "@fontsource-variable/archivo";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";
import { db, eq, asc, series } from "../lib/db";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE,
  SITE_NAME,
  SITE_URL,
} from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "video.other";
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE,
  imageAlt = "If You Make It DIY punk video archive",
  type = "website",
  noindex = false,
  structuredData,
} = Astro.props;
const documentTitle =
  title.startsWith("If You Make It —") || title.endsWith("— If You Make It")
  ? title
  : `${title} — If You Make It`;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site ?? SITE_URL);
const socialImageUrl = new URL(image, Astro.site ?? SITE_URL);
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    logo: `${SITE_URL}/favicon.svg`,
    sameAs: ["https://www.youtube.com/@ifyoumakeit"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    description: DEFAULT_DESCRIPTION,
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
];
const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = JSON.stringify([...baseStructuredData, ...pageStructuredData])
  .replace(/</g, "\\u003c");

function navState(href: string): {
  "aria-current"?: "page" | "location";
  "data-active"?: string;
} {
  const isExact = currentPath === href;
  const isSection = href !== "/" && currentPath.startsWith(href);

  return {
    "aria-current": isExact ? "page" : isSection ? "location" : undefined,
    "data-active": isSection ? "" : undefined,
  };
}

const publishedSeries = await db
  .select()
  .from(series)
  .where(eq(series.publish, 1))
  .orderBy(asc(series.sort));

const staticNavLinks = [
  { label: "Artists", href: "/artists/" },
  { label: "Years", href: "/years/" },
  { label: "Search", href: "/search/" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="theme-color" content="#FF4D8D" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script type="application/ld+json" set:html={jsonLd} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container site-header__inner">
        <a
          class="wordmark"
          href="/"
          aria-label="If You Make It — home"
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          <svg
            class="wordmark__mark"
            viewBox="0 0 64 40"
            aria-hidden="true"
            focusable="false"
          >
            <g
              stroke="#16121A"
              stroke-width="3"
              stroke-linejoin="round"
              stroke-linecap="round"
            >
              <rect x="10" y="6" width="44" height="14" rx="6" fill="#FF4D8D"></rect>
              <rect x="8" y="17" width="48" height="13" rx="5" fill="#FF4D8D"></rect>
              <line x1="32" y1="19" x2="32" y2="28"></line>
              <rect x="6" y="13" width="10" height="17" rx="4" fill="#D81E5B"></rect>
              <rect x="48" y="13" width="10" height="17" rx="4" fill="#D81E5B"></rect>
              <line x1="14" y1="30" x2="14" y2="36"></line>
              <line x1="50" y1="30" x2="50" y2="36"></line>
            </g>
          </svg>
          <span class="wordmark__text">If You Make It</span>
        </a>

        <div class="site-header__nav">
          <span class="site-era" aria-label="Established 2007 to 2014">
            EST. 2007–2014
          </span>
          <nav class="site-nav" aria-label="Primary">
            {
              publishedSeries.map((s) => (
                <a
                  class="site-nav__link"
                  href={`/${s.slug}/`}
                  {...navState(`/${s.slug}/`)}
                >
                  {s.title}
                </a>
              ))
            }
            {
              staticNavLinks.map((item) => (
                <a
                  class="site-nav__link"
                  href={item.href}
                  {...navState(item.href)}
                >
                  {item.label}
                </a>
              ))
            }
          </nav>
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="site-footer__tagline">
          If You Make It — bands on a pink couch since 2007. Long live DIY.
        </p>
        <nav class="site-footer__nav" aria-label="Footer">
          {publishedSeries.map((s) => (
            <a href={`/${s.slug}/`} {...navState(`/${s.slug}/`)}>
              {s.title}
            </a>
          ))}
          {staticNavLinks.map((item) => (
            <a href={item.href} {...navState(item.href)}>{item.label}</a>
          ))}
        </nav>
      </div>
    </footer>

    <style>
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: -3.1rem;
        z-index: 100;
        background: var(--color-yellow);
        color: var(--color-ink);
        border: var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.9rem;
        font-family: var(--font-display);
        text-transform: uppercase;
        text-decoration: none;
        transition: top 0.15s ease;
      }
      .skip-link:focus {
        top: 0.5rem;
      }
      #main:focus {
        outline: none;
      }

      /* ---------- header ---------- */
      .site-header__inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 0.5rem 1.25rem;
        padding-block: 0.7rem;
      }

      .wordmark {
        display: inline-flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        color: var(--color-ink);
        transition: transform 0.12s ease;
      }
      .wordmark:hover {
        text-decoration: none;
        transform: rotate(-1deg);
      }
      .wordmark__mark {
        width: 2.6rem;
        height: auto;
        flex: none;
        filter: drop-shadow(2px 2px 0 var(--color-ink));
        transform-origin: bottom center;
      }
      /* The couch squishes like someone just flopped onto it. */
      .wordmark:hover .wordmark__mark {
        animation: couch-squish 0.5s cubic-bezier(0.28, 1.6, 0.42, 1);
      }
      @keyframes couch-squish {
        30% {
          transform: translateY(1px) scaleY(0.8);
        }
        60% {
          transform: translateY(-1px) scaleY(1.08);
        }
      }
      .wordmark__text {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(1.15rem, 2.6vw, 1.7rem);
        line-height: 1;
        letter-spacing: -0.01em;
        white-space: nowrap;
      }

      /* ---------- nav ---------- */
      .site-header__nav {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.6rem 1rem;
        flex-wrap: wrap;
      }
      .site-era {
        flex: none;
        font-family: var(--font-mono);
        font-size: 0.67rem;
        font-weight: 700;
        line-height: 1;
        letter-spacing: 0.06em;
        color: var(--color-ink);
        background: var(--color-yellow);
        border: var(--border-thin);
        box-shadow: 2px 2px 0 var(--color-ink);
        padding: 0.45em 0.65em;
        transform: rotate(-1.5deg);
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem 0.5rem;
        align-items: center;
      }
      .site-nav__link {
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.04em;
        line-height: 1;
        color: var(--color-ink);
        text-decoration: none;
        border: var(--border-thin);
        border-radius: 999px;
        padding: 0.45em 0.75em;
        background: var(--color-paper);
        transition:
          transform 0.1s ease,
          background 0.1s ease,
          color 0.1s ease;
      }
      .site-nav__link:hover {
        background: var(--color-ink);
        color: var(--color-paper);
        text-decoration: none;
        transform: translateY(-1px) rotate(-1.5deg);
      }
      .site-nav__link[data-active],
      .site-nav__link[aria-current="page"] {
        background: var(--color-ink);
        color: var(--color-paper);
        box-shadow: 2px 2px 0 var(--color-pink);
      }

      @media (max-width: 560px) {
        .site-header__inner {
          justify-content: center;
          text-align: center;
        }
        .wordmark {
          width: 100%;
          justify-content: center;
        }
        .site-header__nav {
          justify-content: center;
        }
        .site-nav {
          justify-content: center;
        }
      }

      /* ---------- footer ---------- */
      .site-footer {
        margin-top: clamp(3rem, 8vw, 6rem);
        border-top: var(--border);
        background: var(--color-ink);
        color: var(--color-paper);
        padding-block: clamp(2rem, 5vw, 3rem);
      }
      .site-footer__tagline {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(1.1rem, 3vw, 1.6rem);
        line-height: 1.05;
        margin: 0 0 1.2rem;
        max-width: 28ch;
      }
      .site-footer__nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.25rem;
      }
      .site-footer__nav a {
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-paper);
        text-decoration: none;
        border-bottom: 2px solid var(--color-pink);
        padding-bottom: 2px;
      }
      .site-footer__nav a:hover {
        color: var(--color-yellow);
        border-color: var(--color-yellow);
      }
      .site-footer__nav a[data-active],
      .site-footer__nav a[aria-current="page"] {
        color: var(--color-yellow);
        border-color: var(--color-yellow);
      }
    </style>
  </body>
</html>
