---
import "@fontsource/anton/400.css";
import "@fontsource-variable/archivo";
import "@fontsource/space-mono/400.css";
import "@fontsource/space-mono/700.css";
import "../styles/global.css";
import { db, eq, asc, series } from "../lib/db";
import {
  DEFAULT_DESCRIPTION,
  DEFAULT_SOCIAL_IMAGE,
  SITE_NAME,
  SITE_URL,
} from "../lib/seo";

interface Props {
  title: string;
  description?: string;
  image?: string;
  imageAlt?: string;
  type?: "website" | "article" | "video.other";
  noindex?: boolean;
  structuredData?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = DEFAULT_DESCRIPTION,
  image = DEFAULT_SOCIAL_IMAGE,
  imageAlt = "If You Make It DIY punk video archive",
  type = "website",
  noindex = false,
  structuredData,
} = Astro.props;
const documentTitle =
  title.startsWith("If You Make It —") || title.endsWith("— If You Make It")
  ? title
  : `${title} — If You Make It`;
const currentPath = Astro.url.pathname;
const canonicalUrl = new URL(currentPath, Astro.site ?? SITE_URL);
const socialImageUrl = new URL(image, Astro.site ?? SITE_URL);
const baseStructuredData = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": `${SITE_URL}/#organization`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    logo: `${SITE_URL}/favicon.svg`,
    sameAs: ["https://www.youtube.com/@ifyoumakeit"],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "@id": `${SITE_URL}/#website`,
    name: SITE_NAME,
    url: `${SITE_URL}/`,
    description: DEFAULT_DESCRIPTION,
    publisher: { "@id": `${SITE_URL}/#organization` },
  },
];
const pageStructuredData = structuredData
  ? Array.isArray(structuredData)
    ? structuredData
    : [structuredData]
  : [];
const jsonLd = JSON.stringify([...baseStructuredData, ...pageStructuredData])
  .replace(/</g, "\\u003c");

function navState(href: string): {
  "aria-current"?: "page" | "location";
  "data-active"?: string;
} {
  const isExact = currentPath === href;
  const isSection = href !== "/" && currentPath.startsWith(href);

  return {
    "aria-current": isExact ? "page" : isSection ? "location" : undefined,
    "data-active": isSection ? "" : undefined,
  };
}

const publishedSeries = await db
  .select()
  .from(series)
  .where(eq(series.publish, 1))
  .orderBy(asc(series.sort));

const staticNavLinks: {
  label: string;
  href: string;
  icon?: "search" | "dice";
}[] = [
  { label: "Artists", href: "/artists/" },
  { label: "Albums", href: "/albums/" },
  { label: "Comics", href: "/comics/" },
  { label: "Years", href: "/years/" },
  { label: "Stats", href: "/stats/" },
  { label: "About", href: "/about/" },
  { label: "Random", href: "/random/", icon: "dice" },
  { label: "Search", href: "/search/", icon: "search" },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <script is:inline>
      // Theme init — must run before first paint to avoid a flash.
      // Stored choice wins; first visit follows the system preference.
      (() => {
        let t;
        try {
          t = localStorage.getItem("theme");
        } catch {}
        if (t !== "light" && t !== "dark") {
          t = matchMedia("(prefers-color-scheme: light)").matches
            ? "light"
            : "dark";
        }
        document.documentElement.dataset.theme = t;
      })();
    </script>
    <title>{documentTitle}</title>
    <meta name="description" content={description} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow, max-image-preview:large"} />
    <meta name="theme-color" content="#16121B" id="meta-theme-color" />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />

    <!-- Open Graph -->
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:locale" content="en_US" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={documentTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content={imageAlt} />
    {image.startsWith("/og-") && (
      <>
        <meta property="og:image:type" content="image/png" />
        <meta property="og:image:width" content="2400" />
        <meta property="og:image:height" content="1260" />
      </>
    )}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={documentTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="twitter:image:alt" content={imageAlt} />
    <script type="application/ld+json" set:html={jsonLd} is:inline />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container site-header__inner">
        <a
          class="wordmark"
          href="/"
          aria-label="If You Make It — home"
          aria-current={currentPath === "/" ? "page" : undefined}
        >
          <svg
            class="wordmark__mark"
            viewBox="0 0 64 40"
            aria-hidden="true"
            focusable="false"
          >
            <g
              stroke="var(--color-ink)"
              stroke-width="3"
              stroke-linejoin="round"
              stroke-linecap="round"
            >
              <rect x="10" y="6" width="44" height="14" rx="6" fill="#FF4D8D"></rect>
              <rect x="8" y="17" width="48" height="13" rx="5" fill="#FF4D8D"></rect>
              <line x1="32" y1="19" x2="32" y2="28"></line>
              <rect x="6" y="13" width="10" height="17" rx="4" fill="#C91550"></rect>
              <rect x="48" y="13" width="10" height="17" rx="4" fill="#C91550"></rect>
              <line x1="14" y1="30" x2="14" y2="36"></line>
              <line x1="50" y1="30" x2="50" y2="36"></line>
            </g>
          </svg>
          <span class="wordmark__text">If You Make It</span>
        </a>

        <div class="site-header__nav">
          <nav class="site-nav" aria-label="Primary">
            {
              publishedSeries.map((s) => (
                <a
                  class="site-nav__link"
                  href={`/${s.slug}/`}
                  {...navState(`/${s.slug}/`)}
                >
                  {s.title}
                </a>
              ))
            }
            {
              staticNavLinks.map((item) => (
                <a
                  class:list={["site-nav__link", { "site-nav__link--icon": item.icon }]}
                  href={item.href}
                  aria-label={item.icon ? item.label : undefined}
                  title={item.icon ? item.label : undefined}
                  {...navState(item.href)}
                >
                  {item.icon === "search" ? (
                    <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <circle cx="10.5" cy="10.5" r="6.5" fill="none" stroke="currentColor" stroke-width="2.5" />
                      <line x1="15.4" y1="15.4" x2="21" y2="21" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" />
                    </svg>
                  ) : item.icon === "dice" ? (
                    <svg class="nav-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                      <rect x="3.5" y="3.5" width="17" height="17" rx="4.5" fill="none" stroke="currentColor" stroke-width="2.5" />
                      <circle cx="8.5" cy="8.5" r="1.6" fill="currentColor" />
                      <circle cx="15.5" cy="8.5" r="1.6" fill="currentColor" />
                      <circle cx="12" cy="12" r="1.6" fill="currentColor" />
                      <circle cx="8.5" cy="15.5" r="1.6" fill="currentColor" />
                      <circle cx="15.5" cy="15.5" r="1.6" fill="currentColor" />
                    </svg>
                  ) : (
                    item.label
                  )}
                </a>
              ))
            }
            <button
              class="theme-toggle"
              id="theme-toggle"
              type="button"
              aria-label="Toggle light/dark theme"
              title="Toggle light/dark theme"
            >
              <svg class="nav-icon theme-toggle__sun" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <circle cx="12" cy="12" r="4.5" fill="none" stroke="currentColor" stroke-width="2.5" />
                <g stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
                  <line x1="12" y1="1.5" x2="12" y2="4.5" />
                  <line x1="12" y1="19.5" x2="12" y2="22.5" />
                  <line x1="1.5" y1="12" x2="4.5" y2="12" />
                  <line x1="19.5" y1="12" x2="22.5" y2="12" />
                  <line x1="4.8" y1="4.8" x2="6.9" y2="6.9" />
                  <line x1="17.1" y1="17.1" x2="19.2" y2="19.2" />
                  <line x1="4.8" y1="19.2" x2="6.9" y2="17.1" />
                  <line x1="17.1" y1="6.9" x2="19.2" y2="4.8" />
                </g>
              </svg>
              <svg class="nav-icon theme-toggle__moon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                <path
                  d="M20 14.5A8.5 8.5 0 0 1 9.5 4 8.5 8.5 0 1 0 20 14.5Z"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  stroke-linejoin="round"
                />
              </svg>
            </button>
          </nav>
        </div>
      </div>
    </header>

    <main id="main" tabindex="-1">
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p class="site-footer__tagline">
          If You Make It — bands on a pink couch since 2007.
        </p>
        <nav class="site-footer__nav" aria-label="Footer">
          {publishedSeries.map((s) => (
            <a href={`/${s.slug}/`} {...navState(`/${s.slug}/`)}>
              {s.title}
            </a>
          ))}
          {staticNavLinks.map((item) => (
            <a href={item.href} {...navState(item.href)}>{item.label}</a>
          ))}
        </nav>
      </div>
    </footer>

    <script is:inline>
      // Theme toggle: flip data-theme on <html>, persist, and keep the
      // browser-chrome color in sync. (Init runs in <head> before paint.)
      document.getElementById("theme-toggle")?.addEventListener("click", () => {
        const root = document.documentElement;
        const next = root.dataset.theme === "light" ? "dark" : "light";
        root.dataset.theme = next;
        try {
          localStorage.setItem("theme", next);
        } catch {}
        document
          .getElementById("meta-theme-color")
          ?.setAttribute("content", next === "light" ? "#FAF3E7" : "#16121B");
      });
    </script>

    <style>
      .skip-link {
        position: absolute;
        left: 0.5rem;
        top: -3.1rem;
        z-index: 100;
        background: var(--color-yellow);
        color: var(--on-accent);
        border: var(--border);
        border-radius: var(--radius);
        padding: 0.5rem 0.9rem;
        font-family: var(--font-display);
        text-transform: uppercase;
        text-decoration: none;
        transition: top 0.15s ease;
      }
      .skip-link:focus {
        top: 0.5rem;
      }
      #main:focus {
        outline: none;
      }

      /* ---------- header: the marquee ---------- */
      .site-header {
        background: var(--color-paper);
        border-bottom: var(--border);
        /* A thin pink misprint line under the cream rule. */
        box-shadow: 0 3px 0 var(--color-pink);
      }
      .site-header__inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        gap: 0.5rem 1rem;
        padding-block: 0.85rem;
      }

      .wordmark {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        text-decoration: none;
        color: var(--color-ink);
      }
      .wordmark:hover {
        text-decoration: none;
      }
      .wordmark__mark {
        width: 2.7rem;
        height: auto;
        flex: none;
        filter: drop-shadow(2px 2px 0 rgba(255, 77, 141, 0.55));
        transform-origin: bottom center;
      }
      /* The couch squishes like someone just flopped onto it. */
      .wordmark:hover .wordmark__mark {
        animation: couch-squish 0.5s cubic-bezier(0.28, 1.6, 0.42, 1);
      }
      @keyframes couch-squish {
        30% {
          transform: translateY(1px) scaleY(0.8);
        }
        60% {
          transform: translateY(-1px) scaleY(1.08);
        }
      }
      .wordmark__text {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(1.3rem, 2.8vw, 1.9rem);
        line-height: 1;
        letter-spacing: 0.02em;
        white-space: nowrap;
        transition: text-shadow 0.12s ease;
      }
      .wordmark:hover .wordmark__text {
        text-shadow:
          2px 2px 0 var(--color-pink),
          4px 4px 0 var(--color-blue);
      }

      /* ---------- nav: the set list ---------- */
      .site-header__nav {
        display: flex;
        align-items: center;
        justify-content: flex-end;
        gap: 0.6rem 1rem;
        flex-wrap: wrap;
        /* Pushes the nav to the right of the wordmark. */
        margin-inline-start: auto;
      }
      .site-nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.15rem 0.2rem;
        align-items: center;
      }
      .site-nav__link {
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 0.72rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        line-height: 1;
        color: var(--color-muted);
        text-decoration: none;
        padding: 0.55em 0.6em;
        border-bottom: 3px solid transparent;
        transition:
          color 0.1s ease,
          border-color 0.1s ease,
          background 0.1s ease;
      }
      .site-nav__link:hover {
        color: var(--color-ink);
        border-bottom-color: var(--color-pink);
        text-decoration: none;
      }
      .site-nav__link[data-active],
      .site-nav__link[aria-current="page"] {
        color: var(--on-accent);
        background: var(--color-pink);
        border-bottom-color: var(--color-pink);
      }

      /* Icon links (Random, Search) — bigger, borderless. The SVG follows
         currentColor; hover/active just recolor and nudge it. Rules come
         after the active block so they win the equal-specificity ties. */
      .site-nav__link--icon,
      .site-nav__link--icon[data-active],
      .site-nav__link--icon[aria-current="page"] {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border: 0;
        background: transparent;
        padding: 0.15em;
        color: var(--color-ink);
      }
      .site-nav__link--icon:hover,
      .site-nav__link--icon[aria-current="page"] {
        background: transparent;
        color: var(--color-pink);
        transform: translateY(-1px) rotate(-6deg) scale(1.08);
      }
      .nav-icon {
        display: block;
        width: 1.5rem;
        height: 1.5rem;
      }

      /* Theme toggle rides with the icon links. The sun shows in the dark
         (click for daylight), the moon shows in the light. */
      .theme-toggle {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0.15em;
        margin: 0;
        border: 0;
        background: transparent;
        color: var(--color-ink);
        cursor: pointer;
        transition:
          color 0.1s ease,
          transform 0.1s ease;
      }
      .theme-toggle:hover {
        color: var(--color-yellow);
        transform: translateY(-1px) rotate(-6deg) scale(1.08);
      }
      .theme-toggle__moon {
        display: none;
      }
      :global([data-theme="light"]) .theme-toggle__sun {
        display: none;
      }
      :global([data-theme="light"]) .theme-toggle__moon {
        display: block;
      }
      :global([data-theme="light"]) .theme-toggle:hover {
        color: var(--color-pink-deep);
      }

      @media (max-width: 560px) {
        .site-header__inner {
          padding-block-end: 0;
        }
        /* Nav becomes a single edge-to-edge scrolling strip: no wrap, swipe
           to reach the tail. Bleed past the container padding so links can
           slide under the screen edge, with a fade hinting at more. */
        .site-header__nav {
          width: 100%;
          margin-inline: calc(-1 * clamp(1rem, 4vw, 2rem));
        }
        .site-nav {
          flex-wrap: nowrap;
          overflow-x: auto;
          width: 100%;
          /* End padding exceeds the fade width so the last link is fully
             visible once scrolled to the end. */
          padding-inline: clamp(1rem, 4vw, 2rem) 2rem;
          padding-block: 0.2rem 0.7rem;
          scrollbar-width: none;
          -webkit-overflow-scrolling: touch;
          mask-image: linear-gradient(
            to right,
            black calc(100% - 1.75rem),
            transparent
          );
        }
        .site-nav::-webkit-scrollbar {
          display: none;
        }
        .site-nav__link,
        .theme-toggle {
          flex: none;
        }
      }

      /* ---------- footer: the back of the flyer ---------- */
      .site-footer {
        margin-top: clamp(3rem, 8vw, 6rem);
        border-top: var(--border);
        box-shadow: 0 -3px 0 var(--color-pink);
        background: var(--color-panel);
        color: var(--color-ink);
        padding-block: clamp(2rem, 5vw, 3.5rem);
      }
      .site-footer__tagline {
        font-family: var(--font-display);
        text-transform: uppercase;
        font-size: clamp(1.4rem, 4vw, 2.4rem);
        line-height: 1.02;
        letter-spacing: 0.015em;
        margin: 0 0 1.4rem;
        max-width: 24ch;
        text-shadow: 3px 3px 0 rgba(255, 77, 141, 0.45);
      }
      .site-footer__nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem 1.25rem;
      }
      .site-footer__nav a {
        font-family: var(--font-mono);
        font-weight: 700;
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.06em;
        color: var(--color-ink);
        text-decoration: none;
        border-bottom: 2px solid var(--color-pink);
        padding-bottom: 2px;
      }
      .site-footer__nav a:hover {
        color: var(--color-yellow);
        border-color: var(--color-yellow);
      }
      .site-footer__nav a[data-active],
      .site-footer__nav a[aria-current="page"] {
        color: var(--color-yellow);
        border-color: var(--color-yellow);
      }
    </style>
  </body>
</html>
