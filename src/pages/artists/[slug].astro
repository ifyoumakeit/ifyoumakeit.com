---
import { db, eq, video, artist, series, album } from "../../lib/db";
import Layout from "../../layouts/Layout.astro";
import VideoCard from "../../components/VideoCard.astro";
import AlbumCard from "../../components/AlbumCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getVideoUrl } from "../../lib/video-url";
import { getAlbumUrl } from "../../lib/album-url";

export async function getStaticPaths() {
  const allArtists = await db.select().from(artist);
  const allVideos = await db.select().from(video).where(eq(video.publish, 1));
  const allAlbums = await db.select().from(album).where(eq(album.publish, 1));

  // Generate a page for any artist with a published video OR album (some bands
  // are in the archive only via their records).
  const artistIdsWithVideos = new Set(allVideos.map((v) => v.artist_id));
  const artistSlugsWithAlbums = new Set(allAlbums.map((a) => a.artist_slug));

  return allArtists
    .filter(
      (a) => artistIdsWithVideos.has(a.id) || artistSlugsWithAlbums.has(a.slug),
    )
    .map((a) => ({
      params: { slug: a.slug },
      props: { artistData: a },
    }));
}

const { artistData } = Astro.props;

// Fetch all published videos for this artist
const allVideos = await db.select().from(video).where(eq(video.publish, 1));
const artistVideos = allVideos
  .filter((v) => v.artist_id === artistData.id)
  .sort((a, b) => new Date(b.recorded_at).getTime() - new Date(a.recorded_at).getTime());

// Albums match the artist by slug (albums carry no artist_id).
const allAlbums = await db.select().from(album).where(eq(album.publish, 1));
const artistAlbums = allAlbums
  .filter((a) => a.artist_slug === artistData.slug)
  .sort((a, b) => new Date(b.released_at).getTime() - new Date(a.released_at).getTime());

const countParts = [
  artistVideos.length &&
    `${artistVideos.length} video${artistVideos.length !== 1 ? "s" : ""}`,
  artistAlbums.length &&
    `${artistAlbums.length} album${artistAlbums.length !== 1 ? "s" : ""}`,
].filter(Boolean);

// Fetch all published series to group by
const allSeries = await db.select().from(series).where(eq(series.publish, 1));
allSeries.sort((a, b) => a.sort - b.sort);
// Group videos by series (ordered by series.sort)
const bySeries = new Map<number, typeof artistVideos>();
for (const v of artistVideos) {
  if (!bySeries.has(v.series_id)) bySeries.set(v.series_id, []);
  bySeries.get(v.series_id)!.push(v);
}

// Ordered series that have videos
const seriesWithVideos = allSeries.filter((s) => bySeries.has(s.id));
---

<Layout
  title={`${artistData.name} — If You Make It`}
  description={`All videos from ${artistData.name}${artistData.hometown ? ` (${artistData.hometown})` : ""} in the If You Make It archive.`}
>
  <div class="container artist-page">
    <header class="artist-header">
      <h1 class="artist-name">{artistData.name}</h1>
      <div class="artist-meta-row">
        {artistData.hometown && (
          <span class="meta-line">{artistData.hometown}</span>
        )}
        {artistData.website && (
          <a class="artist-website btn" href={artistData.website} target="_blank" rel="noopener noreferrer">
            Website <span aria-hidden="true">↗</span>
            <span class="visually-hidden">(opens in a new tab)</span>
          </a>
        )}
      </div>
      <p class="meta-line">{countParts.join(" · ")}</p>
    </header>

    {seriesWithVideos.map((s) => {
      const videos = bySeries.get(s.id)!;
      return (
        <section class="series-group" data-series={s.slug}>
          <SectionHeading title={s.title} count={videos.length} />
          <div class="grid-videos">
            {videos.map((v) => (
              <VideoCard
                title={v.title}
                href={getVideoUrl(v, artistData)}
                artistName={artistData.name}
                seriesTitle={s.title}
                seriesSlug={s.slug}
                recordedAt={new Date(v.recorded_at)}
                provider={v.provider as "youtube" | "vimeo" | "flash"}
                providerId={v.provider_id}
                thumbnailSlug={v.slug}
                showBadge
              />
            ))}
          </div>
        </section>
      );
    })}

    {artistAlbums.length > 0 && (
      <section class="series-group">
        <SectionHeading title="Albums" count={artistAlbums.length} />
        <div class="grid-albums">
          {artistAlbums.map((a) => (
            <AlbumCard
              title={a.title}
              href={getAlbumUrl(a)}
              slug={a.slug}
              artistName={a.artist_name}
              releasedAt={new Date(a.released_at)}
              downloads={a.downloads}
            />
          ))}
        </div>
      </section>
    )}
  </div>
</Layout>

<style>
  .artist-page {
    padding-block: 2rem;
  }
  .artist-header {
    padding-block-end: 1.5rem;
    margin-block-end: 1.5rem;
  }
  .artist-name {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.5rem;
    color: var(--color-pink-deep);
  }
  .artist-meta-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-block-end: 0.5rem;
  }
  .artist-website {
    font-size: 0.85rem;
  }
  .series-group {
    padding-block: 2rem;
    border-top: var(--border);
  }
  .grid-albums {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 1.25rem;
    margin-block-start: 0.75rem;
  }
</style>
