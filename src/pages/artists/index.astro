---
import { db, eq, video, artist } from "../../lib/db";
import Layout from "../../layouts/Layout.astro";
import SectionHeading from "../../components/SectionHeading.astro";

// Fetch all artists and published videos
const allArtists = await db.select().from(artist);
const allVideos = await db.select().from(video).where(eq(video.publish, 1));

// Count videos per artist (published only)
const videoCountByArtist = new Map<number, number>();
for (const v of allVideos) {
  videoCountByArtist.set(v.artist_id, (videoCountByArtist.get(v.artist_id) ?? 0) + 1);
}

// Only include artists that have at least one published video
const activeArtists = allArtists
  .filter((a) => (videoCountByArtist.get(a.id) ?? 0) > 0)
  .sort((a, b) => a.name.localeCompare(b.name, "en-US"));

// Group by first letter
const byLetter = new Map<string, typeof activeArtists>();
for (const a of activeArtists) {
  const letter = a.name[0]?.toUpperCase() ?? "#";
  const key = /[A-Z]/.test(letter) ? letter : "#";
  if (!byLetter.has(key)) byLetter.set(key, []);
  byLetter.get(key)!.push(a);
}
const sortedLetters = [...byLetter.keys()].sort((a, b) => {
  if (a === "#") return 1;
  if (b === "#") return -1;
  return a.localeCompare(b);
});
---

<Layout title="Artists — If You Make It" description="Browse all artists in the If You Make It DIY punk video archive.">
  <div class="container artists-page">
    <header class="page-header">
      <h1 class="page-title">Artists</h1>
      <p class="meta-line">{activeArtists.length} artist{activeArtists.length !== 1 ? "s" : ""}</p>
    </header>

    <nav class="letter-nav" aria-label="Jump to letter">
      {sortedLetters.map((l) => (
        <a class="tag-chip" href={`#letter-${l}`}>{l}</a>
      ))}
    </nav>

    {sortedLetters.map((letter) => {
      const group = byLetter.get(letter)!;
      return (
        <section class="letter-group" id={`letter-${letter}`}>
          <SectionHeading title={letter} count={group.length} />
          <ul class="artist-list">
            {group.map((a) => {
              const count = videoCountByArtist.get(a.id) ?? 0;
              return (
                <li class="artist-row">
                  <a class="artist-name" href={`/artists/${a.slug}/`}>{a.name}</a>
                  {a.hometown && <span class="artist-hometown">{a.hometown}</span>}
                  <span class="artist-count">{count} video{count !== 1 ? "s" : ""}</span>
                </li>
              );
            })}
          </ul>
        </section>
      );
    })}
  </div>
</Layout>

<style>
  .artists-page {
    padding-block: 2rem;
  }
  .page-header {
    padding-block-end: 1.5rem;
    border-bottom: var(--border);
    margin-block-end: 1.5rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.25rem;
  }
  .letter-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-block-end: 2rem;
  }
  .letter-group {
    margin-block-end: 2rem;
  }
  .artist-list {
    list-style: none;
    padding: 0;
    margin: 0.75rem 0 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .artist-row {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid color-mix(in srgb, var(--color-ink) 8%, transparent);
    flex-wrap: wrap;
  }
  .artist-name {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-ink);
    text-decoration: none;
    flex: 0 0 auto;
  }
  .artist-name:hover {
    color: var(--color-pink);
  }
  .artist-hometown {
    color: var(--color-muted);
    font-size: 0.9rem;
    flex: 1 1 auto;
  }
  .artist-count {
    color: var(--color-muted);
    font-size: 0.85rem;
    white-space: nowrap;
    margin-inline-start: auto;
  }
</style>
