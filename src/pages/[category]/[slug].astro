---
import { db, post, category, postmeta, eq, and } from "astro:db";
import Layout from "../../layouts/Layout.astro";

const { category: categorySlug, slug } = Astro.params;

const [result] = await db
  .select({
    id: post.id,
    title: post.title,
    subtitle: post.subtitle,
    body: post.body,
    date: post.date,
    bgcolor: post.bgcolor,
    category_title: category.title,
    category_slug: category.slug,
  })
  .from(post)
  .innerJoin(category, eq(post.category_id, category.id))
  .where(
    and(
      eq(post.title_slug, slug as string),
      eq(category.slug, categorySlug as string),
      eq(post.publish, 1)
    )
  );

if (!result) {
  return Astro.redirect("/404");
}

const meta = await db
  .select()
  .from(postmeta)
  .where(eq(postmeta.post_id, result.id));
---

<Layout title={result.title}>
  <main>
    <article>
      <h1>{result.title}</h1>
      {result.subtitle && <p>{result.subtitle}</p>}
      <div set:html={result.body} />
    </article>
  </main>
</Layout>
