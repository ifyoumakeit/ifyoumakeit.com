---
import { db, eq, video, artist, series } from "../../lib/db";
import Layout from "../../layouts/Layout.astro";
import { getLocalThumb } from "../../lib/thumbs";
import { getVideoUrl } from "../../lib/video-url";
import { videoNotes } from "../../data/video-notes";

const allVideos = await db.select().from(video).where(eq(video.publish, 1));
const allArtists = await db.select().from(artist);
const allSeries = await db.select().from(series).where(eq(series.publish, 1));
const artistById = new Map(allArtists.map((a) => [a.id, a]));
const seriesById = new Map(allSeries.map((s) => [s.id, s]));

// One continuous chronological run, oldest first — scroll the whole story
// from the first couch session onward. Grouped year → month for the spine.
const chronological = [...allVideos].sort(
  (a, b) => new Date(a.recorded_at).getTime() - new Date(b.recorded_at).getTime()
);

const monthName = new Intl.DateTimeFormat("en-US", {
  month: "long",
  timeZone: "UTC",
});
const dayLabel = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  timeZone: "UTC",
});

type Entry = (typeof chronological)[number];
type MonthGroup = { label: string; videos: Entry[] };
type YearGroup = { year: number; count: number; months: MonthGroup[] };

const yearGroups: YearGroup[] = [];
for (const v of chronological) {
  const d = new Date(v.recorded_at);
  const y = d.getUTCFullYear();
  const m = monthName.format(d);
  let yg = yearGroups.at(-1);
  if (!yg || yg.year !== y) {
    yg = { year: y, count: 0, months: [] };
    yearGroups.push(yg);
  }
  let mg = yg.months.at(-1);
  if (!mg || mg.label !== m) {
    mg = { label: m, videos: [] };
    yg.months.push(mg);
  }
  mg.videos.push(v);
  yg.count++;
}

function thumbFor(v: Entry): string | null {
  return (
    getLocalThumb(v.slug) ??
    (v.provider === "youtube"
      ? `https://i.ytimg.com/vi/${v.provider_id}/mqdefault.jpg`
      : null)
  );
}
---

<Layout
  title="Timeline — If You Make It"
  description={`Scroll through every If You Make It recording in order, ${yearGroups[0]?.year}–${yearGroups.at(-1)?.year}.`}
>
  <div class="container timeline-page">
    <header class="page-header">
      <h1 class="page-title">Timeline</h1>
      <p class="meta-line">
        {chronological.length} recordings, {yearGroups.length} years, one scroll
      </p>
      <ul class="legend" aria-label="Series key">
        {allSeries.map((s) => (
          <li class="legend__item" data-series={s.slug}>
            <span class="legend__dot" aria-hidden="true"></span>
            {s.title}
          </li>
        ))}
      </ul>
    </header>

    <ol class="timeline">
      {yearGroups.map((yg) => (
        <li class="year-block">
          <div class="year-rail">
            <a class="year-sticker" href={`/years/${yg.year}/`}>
              {yg.year}
              <span class="year-sticker__count">{yg.count}</span>
            </a>
          </div>

          <ol class="year-entries">
            {yg.months.map((mg) => (
              <li class="month-block">
                <h2 class="month-label">
                  {mg.label}
                  <span class="visually-hidden">{yg.year}</span>
                </h2>
                <ol class="month-entries">
                  {mg.videos.map((v) => {
                    const a = artistById.get(v.artist_id);
                    const s = seriesById.get(v.series_id);
                    const thumb = thumbFor(v);
                    const note = videoNotes[v.slug];
                    return (
                      <li>
                        {note && <p class="entry-note">{note}</p>}
                        <a
                          class="entry"
                          href={getVideoUrl(v, a!)}
                          data-series={s?.slug}
                        >
                          <span class="entry__dot" aria-hidden="true"></span>
                          {thumb ? (
                            <img
                              class="entry__thumb"
                              src={thumb}
                              alt=""
                              loading="lazy"
                              decoding="async"
                              width="320"
                              height="180"
                            />
                          ) : (
                            <span class="entry__thumb entry__thumb--empty" aria-hidden="true"></span>
                          )}
                          <span class="entry__text">
                            <span class="entry__artist">{a?.name}</span>
                            <span class="entry__title">{v.title}</span>
                          </span>
                          <span class="entry__date meta-line">
                            {dayLabel.format(new Date(v.recorded_at))}
                          </span>
                        </a>
                      </li>
                    );
                  })}
                </ol>
              </li>
            ))}
          </ol>
        </li>
      ))}
    </ol>
  </div>
</Layout>

<style>
  .timeline-page {
    padding-block: 2rem;
  }
  .page-header {
    padding-block-end: 1.5rem;
    border-bottom: var(--border);
    margin-block-end: 0;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.25rem;
    animation: stamp-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    transform-origin: left bottom;
  }

  /* series color key */
  .legend {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem 1.2rem;
    padding: 0;
    margin: 0.85rem 0 0;
  }
  .legend__item {
    display: inline-flex;
    align-items: center;
    gap: 0.45em;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .legend__dot {
    width: 0.8em;
    height: 0.8em;
    border-radius: 999px;
    border: 2px solid var(--color-ink);
    background: var(--accent, var(--color-pink));
  }

  /* ---------- timeline structure ---------- */
  .timeline {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .year-block {
    display: grid;
    grid-template-columns: minmax(7.5rem, auto) 1fr;
    gap: 0 clamp(1.25rem, 4vw, 3rem);
    border-bottom: var(--border);
    padding-block: 2rem;
  }
  .year-block:last-child {
    border-bottom: 0;
  }

  /* Year sticker rides along while its months scroll past. */
  .year-rail {
    position: relative;
  }
  .year-sticker {
    position: sticky;
    top: 1rem;
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 4.5vw, 3rem);
    line-height: 1;
    color: var(--color-ink);
    background: var(--color-paper);
    text-decoration: none;
    border: var(--border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-hard-sm);
    padding: 0.35em 0.4em 0.28em;
    transform: rotate(-2deg);
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease,
      color 0.12s ease;
  }
  .year-sticker:hover {
    color: var(--color-pink-deep);
    transform: rotate(-2deg) translate(-2px, -2px);
    box-shadow: var(--shadow-hard);
    text-decoration: none;
  }
  .year-sticker__count {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.78rem;
    color: var(--color-paper);
    background: var(--color-ink);
    border-radius: 999px;
    padding: 0.3em 0.6em;
    transform: translateY(-0.9em) rotate(6deg);
  }

  /* Curator note — a scrawled index card pinned above the recording it
     introduces. Sits on the spine just before its entry. */
  .entry-note {
    position: relative;
    margin: 0.2rem 0 0.7rem;
    font-family: var(--font-mono);
    font-size: 0.76rem;
    line-height: 1.45;
    color: var(--color-ink);
    background: var(--color-yellow);
    border: var(--border-thin);
    border-left: 4px solid var(--color-pink);
    border-radius: 2px;
    box-shadow: var(--shadow-hard-sm);
    padding: 0.55rem 0.75rem;
    transform: rotate(-0.5deg);
  }
  /* dot pinning the note to the spine, matching the entries */
  .entry-note::before {
    content: "";
    position: absolute;
    left: calc(-1 * clamp(1.1rem, 3vw, 1.75rem) - 9px - 2px);
    top: 1rem;
    width: 11px;
    height: 11px;
    border-radius: 999px;
    border: 3px solid var(--color-ink);
    background: var(--color-pink);
  }

  /* the inked spine */
  .year-entries {
    list-style: none;
    padding: 0 0 0 clamp(1.1rem, 3vw, 1.75rem);
    margin: 0;
    border-left: 3px solid var(--color-ink);
  }
  .month-block {
    margin-block-end: 1.75rem;
  }
  .month-block:last-child {
    margin-block-end: 0;
  }
  .month-label {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    line-height: 1;
    color: var(--color-ink);
    background: var(--color-yellow);
    border: var(--border-thin);
    display: inline-block;
    padding: 0.45em 0.7em;
    margin: 0 0 0.85rem;
    transform: rotate(-1.2deg);
    box-shadow: 2px 2px 0 var(--color-ink);
  }
  .month-entries {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* ---------- entries ---------- */
  .entry {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.85rem;
    text-decoration: none;
    color: var(--color-ink);
    background: var(--color-paper);
    border: var(--border-thin);
    border-radius: var(--radius);
    padding: 0.45rem 0.7rem 0.45rem 0.55rem;
    transition:
      transform 0.12s ease,
      box-shadow 0.12s ease;
  }
  .entry:hover {
    text-decoration: none;
    transform: translate(-2px, -2px) rotate(-0.4deg);
    box-shadow: var(--shadow-hard-sm);
  }
  .entry:focus-visible {
    outline: 3px solid var(--color-blue);
    outline-offset: 2px;
  }
  /* dot pinned onto the spine, colored by series */
  .entry__dot {
    position: absolute;
    left: calc(-1 * clamp(1.1rem, 3vw, 1.75rem) - 9px);
    top: 50%;
    width: 11px;
    height: 11px;
    transform: translateY(-50%);
    border-radius: 999px;
    border: 3px solid var(--color-ink);
    background: var(--accent, var(--color-pink));
  }
  .entry__thumb {
    flex: none;
    width: 5.25rem;
    aspect-ratio: 16 / 9;
    height: auto;
    object-fit: cover;
    border: var(--border-thin);
    border-radius: 2px;
    background: var(--accent, var(--color-pink));
  }
  .entry__thumb--empty {
    display: block;
    background-image: repeating-linear-gradient(
      -45deg,
      transparent 0,
      transparent 6px,
      rgba(22, 18, 26, 0.12) 6px,
      rgba(22, 18, 26, 0.12) 12px
    );
  }
  .entry__text {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .entry__artist {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 0.95rem;
    line-height: 1;
  }
  .entry:hover .entry__artist {
    color: var(--accent-text, var(--color-pink-deep));
  }
  .entry__title {
    font-size: 0.85rem;
    color: var(--color-muted);
    line-height: 1.25;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .entry__date {
    margin-left: auto;
    flex: none;
    white-space: nowrap;
  }

  /* Entries drift in as they cross into view (scroll-driven, where
     supported — elsewhere they're simply visible). Progress is scrubbed
     by scroll, so the motion spans a long stretch of viewport (bottom
     edge up to 30% in) and animates only opacity + translate — no
     rotation/scale, which shimmer when scrubbed. */
  @supports (animation-timeline: view()) {
    .entry {
      animation: drift-in linear both;
      animation-timeline: view();
      animation-range: entry 0% cover 30%;
    }
    @keyframes drift-in {
      from {
        opacity: 0.15;
        transform: translateY(14px);
      }
      to {
        opacity: 1;
        transform: none;
      }
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .entry {
      animation: none;
    }
  }

  /* ---------- small screens ---------- */
  @media (max-width: 640px) {
    .year-block {
      display: block;
      padding-block: 1.5rem;
    }
    .year-rail {
      position: sticky;
      top: 0;
      z-index: 3;
      background: var(--color-paper);
      padding-block: 0.5rem;
      margin-block-end: 1rem;
    }
    .year-sticker {
      position: static;
      font-size: 1.6rem;
    }
    .entry__date {
      display: none;
    }
  }
</style>
