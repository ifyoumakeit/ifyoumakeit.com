---
import { db, eq, video, artist } from "astro:db";
import Layout from "../../layouts/Layout.astro";

const allVideos = await db.select().from(video).where(eq(video.publish, 1));
const allArtists = await db.select().from(artist);
const artistById = new Map(allArtists.map((a) => [a.id, a]));

// Group videos by UTC year
const byYear = new Map<number, typeof allVideos>();
for (const v of allVideos) {
  const y = new Date(v.recorded_at).getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(v);
}

const sortedYears = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title="Years — If You Make It" description="Browse the If You Make It archive by year.">
  <div class="container years-page">
    <header class="page-header">
      <h1 class="page-title">Timeline</h1>
      <p class="meta-line">{sortedYears.length} year{sortedYears.length !== 1 ? "s" : ""} of recordings</p>
    </header>

    <ol class="year-timeline" reversed>
      {sortedYears.map((year) => {
        const videos = byYear.get(year)!;
        const artistNames = [
          ...new Map(
            videos.map((v) => [v.artist_id, artistById.get(v.artist_id)?.name ?? ""])
          ).values(),
        ]
          .filter(Boolean)
          .sort((a, b) => a.localeCompare(b, "en-US"));

        return (
          <li class="year-row">
            <a class="year-number" href={`/years/${year}/`}>{year}</a>
            <div class="year-detail">
              <span class="year-count meta-line">{videos.length} video{videos.length !== 1 ? "s" : ""}</span>
              <p class="year-artists">{artistNames.join(", ")}</p>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</Layout>

<style>
  .years-page {
    padding-block: 2rem;
  }
  .page-header {
    padding-block-end: 1.5rem;
    border-bottom: var(--border);
    margin-block-end: 1.5rem;
  }
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.25rem;
  }
  .year-timeline {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }
  .year-row {
    display: flex;
    align-items: flex-start;
    gap: 2rem;
    padding: 1.5rem 0;
    border-bottom: var(--border);
  }
  .year-number {
    font-family: var(--font-display);
    font-size: clamp(3rem, 8vw, 5rem);
    font-weight: 900;
    line-height: 1;
    color: var(--color-ink);
    text-decoration: none;
    flex: 0 0 auto;
    min-width: 5rem;
    transition: color 0.1s ease;
  }
  .year-number:hover {
    color: var(--color-pink);
  }
  .year-detail {
    padding-block-start: 0.5rem;
    flex: 1 1 auto;
    min-width: 0;
  }
  .year-count {
    display: block;
    margin-block-end: 0.35rem;
  }
  .year-artists {
    margin: 0;
    font-size: 0.9rem;
    color: var(--color-muted);
    line-height: 1.5;
  }
</style>
