---
import { db, eq, video, artist, series, album, comic } from "../../lib/db";
import Layout from "../../layouts/Layout.astro";
import { getVideoUrl } from "../../lib/video-url";
import { getAlbumUrl } from "../../lib/album-url";
import { getComicUrl } from "../../lib/comic-url";

const allVideos = await db.select().from(video).where(eq(video.publish, 1));
const allArtists = await db.select().from(artist);
const allSeries = await db.select().from(series).where(eq(series.publish, 1));
const allAlbums = await db.select().from(album).where(eq(album.publish, 1));
const allComics = await db.select().from(comic).where(eq(comic.publish, 1));
const artistById = new Map(allArtists.map((a) => [a.id, a]));
const seriesById = new Map(allSeries.map((s) => [s.id, s]));

// Compact, build-time search index inlined into the page — no fetch, no
// loading state. Short keys keep the payload small. Videos and album releases
// share the record shape; `k` carries the accent (series slug, or "albums").
const videoIndex = allVideos.map((v) => {
  const a = artistById.get(v.artist_id);
  const s = seriesById.get(v.series_id);
  return {
    t: v.title,
    a: a?.name ?? "",
    s: s?.title ?? "",
    k: s?.slug ?? "",
    y: new Date(v.recorded_at).getUTCFullYear(),
    u: a ? getVideoUrl(v, a) : `/video/${v.slug}/`,
  };
});
const albumIndex = allAlbums.map((al) => ({
  t: al.title,
  a: al.artist_name,
  s: "Album",
  k: "albums",
  y: new Date(al.released_at).getUTCFullYear(),
  u: getAlbumUrl(al),
}));
// Comics carry no reliable year — `y: ""` sorts them after dated records and
// hides the year in the result meta.
const comicIndex = allComics.map((c) => ({
  t: c.title,
  a: c.artist_name,
  s: "Comic",
  k: "comics",
  y: "" as number | "",
  u: getComicUrl(c),
}));
const index = [...videoIndex, ...albumIndex, ...comicIndex].sort(
  (x, y) => (Number(y.y) || 0) - (Number(x.y) || 0) || x.a.localeCompare(y.a),
);

const videoCount = videoIndex.length;
const albumCount = albumIndex.length;
const comicCount = comicIndex.length;
const indexJson = JSON.stringify(index).replace(/</g, "\\u003c");
---

<Layout
  title="Search — If You Make It"
  description="Search the If You Make It archive by band, song, series, or year."
  noindex={true}
>
  <div class="container search-page">
    <header class="search-header">
      <h1 class="search-title">Search</h1>
      <form class="search-form" role="search" action="/search/" method="get">
        <input
          class="search-input"
          type="search"
          name="q"
          id="q"
          placeholder="band, album, song, year…"
          autocomplete="off"
          autocapitalize="off"
          spellcheck="false"
          aria-label="Search the archive"
          enterkeyhint="search"
        />
      </form>
      <p class="search-status meta-line" id="status" aria-live="polite">
        {videoCount} videos, {albumCount} albums &amp; {comicCount} comics
      </p>
    </header>

    <ul class="results" id="results"></ul>

    <template id="result-template">
      <li>
        <a class="result">
          <span class="result__dot" aria-hidden="true"></span>
          <span class="result__text">
            <span class="result__artist"></span>
            <span class="result__title"></span>
          </span>
          <span class="result__meta meta-line"></span>
        </a>
      </li>
    </template>

    <noscript>
      <p class="search-noscript">
        Search needs JavaScript. Browse by
        <a href="/artists/">artist</a> or <a href="/years/">year</a> instead.
      </p>
    </noscript>
  </div>

  <script
    type="application/json"
    id="search-index"
    set:html={indexJson}
    is:inline
  />

  <script>
    // Live client-side filtering over the build-time index emitted above.
    interface Rec {
      t: string; // title
      a: string; // artist
      s: string; // series / kind label
      k: string; // accent key (series slug, "albums", "comics")
      y: number | ""; // year ("" for comics)
      u: string; // url
      h?: string; // lowercased haystack, precomputed below
    }

    const indexEl = document.getElementById("search-index");
    const data: Rec[] = indexEl?.textContent
      ? JSON.parse(indexEl.textContent)
      : [];
    // Precompute a lowercase haystack per record once.
    for (const d of data) {
      d.h = `${d.t} ${d.a} ${d.s} ${d.y}`.toLowerCase();
    }

    const input = document.getElementById("q") as HTMLInputElement | null;
    const results = document.getElementById("results");
    const status = document.getElementById("status");
    const template = document.getElementById(
      "result-template",
    ) as HTMLTemplateElement | null;

    if (input && results && status && template) {
      init(input, results, status, template);
    }

    function init(
      input: HTMLInputElement,
      results: HTMLElement,
      status: HTMLElement,
      template: HTMLTemplateElement,
    ) {
      const initialStatus = status.textContent?.trim() ?? "";
      const row = template.content.firstElementChild;
      if (!row) return;

      const render = (q: string) => {
        const query = q.trim().toLowerCase();
        if (!query) {
          results.replaceChildren();
          status.textContent = initialStatus;
          return;
        }
        const terms = query.split(/\s+/);
        const out: Rec[] = [];
        for (let i = 0; i < data.length && out.length < 120; i++) {
          const d = data[i];
          if (terms.every((t) => (d.h ?? "").includes(t))) out.push(d);
        }

        if (!out.length) {
          const empty = document.createElement("li");
          empty.className = "results__empty";
          empty.textContent = `Nothing matches “${q.trim()}”. Try a band, album, or song.`;
          results.replaceChildren(empty);
          status.textContent = "No matches";
          return;
        }

        // Clone the <template> per hit and fill text/attributes — textContent
        // escapes for us, so no manual HTML-escaping is needed.
        const frag = document.createDocumentFragment();
        for (const r of out) {
          const node = row.cloneNode(true) as HTMLElement;
          const link = node.querySelector("a.result") as HTMLAnchorElement;
          link.href = r.u;
          link.dataset.series = r.k;
          (node.querySelector(".result__artist") as HTMLElement).textContent =
            r.a;
          (node.querySelector(".result__title") as HTMLElement).textContent =
            r.t;
          (node.querySelector(".result__meta") as HTMLElement).textContent = r.y
            ? `${r.s} · ${r.y}`
            : r.s;
          frag.appendChild(node);
        }
        results.replaceChildren(frag);
        status.textContent = `${out.length} ${out.length === 1 ? "result" : "results"}`;
      };

      // Deep-link support: ?q= prefills and the URL updates as you type.
      const initial = new URLSearchParams(location.search).get("q") || "";
      input.value = initial;

      let raf = 0;
      const update = () => {
        cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          render(input.value);
          const u = input.value
            ? `?q=${encodeURIComponent(input.value)}`
            : location.pathname;
          history.replaceState(null, "", u);
        });
      };
      input.addEventListener("input", update);
      // Don't reload the page on Enter — it's already live.
      document
        .querySelector(".search-form")
        ?.addEventListener("submit", (e) => {
          e.preventDefault();
          input.blur();
        });

      if (initial) render(initial);
      input.focus();
    }
  </script>
</Layout>

<style>
  .search-page {
    padding-block: 2rem;
    min-height: 60vh;
  }
  .search-header {
    padding-block-end: 1.25rem;
    border-bottom: var(--border);
    margin-block-end: 1.25rem;
  }
  .search-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.85rem;
    animation: stamp-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) backwards;
    transform-origin: left bottom;
  }
  .search-form {
    margin: 0;
  }
  .search-input {
    width: 100%;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: clamp(1.1rem, 3vw, 1.6rem);
    color: var(--color-ink);
    background: transparent;
    border: 0;
    border-bottom: 2px solid var(--color-line);
    border-radius: 0;
    padding: 0.6em 0.1em;
    transition: border-color 0.12s ease;
  }
  .search-input::placeholder {
    color: var(--color-muted);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.85em;
  }
  .search-input:focus {
    outline: none;
    border-bottom-color: var(--color-pink);
  }
  /* hide the native clear button so the zine look stays clean */
  .search-input::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }
  .search-status {
    margin: 0.85rem 0 0;
  }

  .results {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  /* Result rows are injected via innerHTML, so they never receive Astro's
     scope attribute — these selectors must be global. Anchoring each under
     #results (which IS in the template) keeps them from leaking site-wide. */
  #results :global(.result) {
    position: relative;
    display: flex;
    align-items: center;
    gap: 1.15rem;
    text-decoration: none;
    color: var(--color-ink);
    background: var(--color-panel);
    border: 1px solid var(--color-line);
    border-radius: var(--radius);
    padding: 1rem 1.2rem;
    transition: border-color 0.12s ease;
  }
  #results :global(.result:hover) {
    text-decoration: none;
    border-color: var(--accent, var(--color-pink));
  }
  #results :global(.result:focus-visible) {
    outline: 3px solid var(--color-yellow);
    outline-offset: 2px;
  }
  #results :global(.result__dot) {
    flex: none;
    width: 0.85rem;
    height: 0.85rem;
    border-radius: 999px;
    background: var(--accent, var(--color-pink));
  }
  /* Album results carry no series — give them the albums blue accent. */
  #results :global(.result[data-series="albums"]) {
    --accent: var(--color-blue);
    --accent-text: var(--color-blue);
  }
  /* Comics get the punk-yellow accent. */
  #results :global(.result[data-series="comics"]) {
    --accent: var(--color-yellow);
    --accent-text: var(--color-pink-deep);
  }
  #results :global(.result__text) {
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  #results :global(.result__artist) {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 1.15rem;
    line-height: 1.05;
  }
  #results :global(.result:hover .result__artist) {
    color: var(--accent-text, var(--color-pink-deep));
  }
  #results :global(.result__title) {
    font-size: 0.95rem;
    color: var(--color-muted);
    line-height: 1.35;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  #results :global(.result__meta) {
    margin-left: auto;
    padding-left: 0.85rem;
    flex: none;
    white-space: nowrap;
  }
  #results :global(.results__empty) {
    font-family: var(--font-body);
    color: var(--color-muted);
    padding-block: 1.5rem;
  }
  .search-noscript {
    color: var(--color-muted);
    padding-block: 1rem;
  }

  @media (max-width: 560px) {
    #results :global(.result__meta) {
      display: none;
    }
  }
</style>
