---
import { db, eq, video, artist, series } from "astro:db";
import Layout from "../../layouts/Layout.astro";
import VideoCard from "../../components/VideoCard.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import { getVideoUrl } from "../../lib/video-url";

export async function getStaticPaths() {
  const allSeries = await db
    .select()
    .from(series)
    .where(eq(series.publish, 1));

  return allSeries.map((s) => ({
    params: { series: s.slug },
    props: { seriesData: s },
  }));
}

const { seriesData } = Astro.props;

// Fetch all published videos for this series
const allVideos = await db
  .select()
  .from(video)
  .where(eq(video.publish, 1));

const seriesVideos = allVideos
  .filter((v) => v.series_id === seriesData.id)
  .sort((a, b) => new Date(b.recorded_at).getTime() - new Date(a.recorded_at).getTime());

const allArtists = await db.select().from(artist);
const artistMap = new Map(allArtists.map((a) => [a.id, a]));

// Group by year (UTC), newest year first
const byYear = new Map<number, typeof seriesVideos>();
for (const v of seriesVideos) {
  const y = new Date(v.recorded_at).getUTCFullYear();
  if (!byYear.has(y)) byYear.set(y, []);
  byYear.get(y)!.push(v);
}
const sortedYears = [...byYear.keys()].sort((a, b) => b - a);
---

<Layout title={seriesData.title} description={seriesData.description ?? undefined}>
  <div data-series={seriesData.slug}>

    <header class="series-header container">
      <h1 class="series-title">{seriesData.title}</h1>
      {seriesData.description && (
        <p class="series-description">{seriesData.description}</p>
      )}
      <p class="meta-line">{seriesVideos.length} video{seriesVideos.length !== 1 ? "s" : ""}</p>
    </header>

    <div class="container series-body">
      {sortedYears.map((year) => {
        const yearVideos = byYear.get(year)!;
        return (
          <section class="year-group">
            <SectionHeading title={String(year)} href={`/years/${year}/`} count={yearVideos.length} />
            <div class="grid-videos">
              {yearVideos.map((v) => {
                const a = artistMap.get(v.artist_id);
                return (
                  <VideoCard
                    title={v.title}
                    href={getVideoUrl(v, a!)}
                    artistName={a?.name ?? ""}
                    seriesTitle={seriesData.title}
                    seriesSlug={seriesData.slug}
                    recordedAt={new Date(v.recorded_at)}
                    provider={v.provider as "youtube" | "vimeo" | "flash"}
                    providerId={v.provider_id}
                    thumbnailSlug={v.slug}
                  />
                );
              })}
            </div>
          </section>
        );
      })}

      {seriesVideos.length === 0 && (
        <p class="empty">No videos yet in this series.</p>
      )}
    </div>

  </div>
</Layout>

<style>
  .series-header {
    padding-block: 2.5rem 1.5rem;
    border-bottom: var(--border);
  }
  .series-title {
    font-family: var(--font-display);
    font-size: clamp(2rem, 5vw, 3.5rem);
    margin: 0 0 0.5rem;
    color: var(--accent-text, var(--color-ink));
  }
  .series-description {
    font-size: 1.05rem;
    max-width: 60ch;
    margin: 0 0 0.5rem;
  }
  .series-body {
    padding-block: 1.5rem;
  }
  .year-group {
    margin-block-end: 2.5rem;
  }
  .empty {
    color: var(--color-muted);
    font-style: italic;
  }
</style>
