---
import { db, eq, video, artist, series, tag, videoTag } from "../lib/db";
import Layout from "../layouts/Layout.astro";
import VideoCard from "../components/VideoCard.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getLocalThumb } from "../lib/thumbs";
import { getVideoUrl } from "../lib/video-url";
import { renderMarkdown } from "../lib/markdown";

// Fetch all published series ordered by sort
const allSeries = await db.select().from(series).where(eq(series.publish, 1));
allSeries.sort((a, b) => a.sort - b.sort);

// Fetch all published videos with artist and series info
const allVideos = await db.select().from(video).where(eq(video.publish, 1));

const allArtists = await db.select().from(artist);
const artistMap = new Map(allArtists.map((a) => [a.id, a]));
const seriesMap = new Map(allSeries.map((s) => [s.id, s]));

// Stats
const totalVideos = allVideos.length;
const uniqueArtistIds = new Set(allVideos.map((v) => v.artist_id));
const totalArtists = uniqueArtistIds.size;
const years = allVideos.map((v) => new Date(v.recorded_at).getUTCFullYear());
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const totalYears = maxYear - minYear + 1;
const cap = 6;

const totalViews = allVideos.reduce((sum, v) => sum + v.views, 0);
const formattedViews = new Intl.NumberFormat("en-US", {
  notation: "compact",
  maximumFractionDigits: 1,
}).format(totalViews);

// Hero video — "On this day": a video recorded on today's UTC month/day in any
// year (most-watched wins ties). When nothing matches exactly, fall back to a
// recording from *around now* — first this week (within 3 days, any year),
// then this month — so the hero stays tied to the calendar instead of jumping
// to a random date. UTC throughout to stay stable across machines.
const heroPool = allVideos.filter(
  (v) => artistMap.has(v.artist_id) && seriesMap.has(v.series_id),
);

const now = new Date();
// Day-of-year in a fixed common year, so month/day compare regardless of year.
const CUMULATIVE_DAYS = [0, 31, 59, 90, 120, 151, 181, 212, 243, 273, 304, 334];
const dayOfYear = (d: Date) =>
  CUMULATIVE_DAYS[d.getUTCMonth()] + d.getUTCDate();
const todayDoy = dayOfYear(now);
const calendarDistance = (d: Date) => {
  const diff = Math.abs(dayOfYear(d) - todayDoy);
  return Math.min(diff, 365 - diff); // wrap around the year boundary
};

// Deterministic "random" that advances each day, so daily builds rotate the
// pick within a bucket while staying reproducible for a given date.
const daySeed = now.getUTCFullYear() * 366 + todayDoy;
const pickDaily = <T extends { id: number }>(rows: T[]): T | null =>
  rows.length
    ? [...rows].sort((a, b) => a.id - b.id)[daySeed % rows.length]
    : null;

const onThisDay = heroPool
  .filter((v) => calendarDistance(new Date(v.recorded_at)) === 0)
  .sort((a, b) => b.views - a.views);
const thisWeek = heroPool.filter(
  (v) => calendarDistance(new Date(v.recorded_at)) <= 3,
);
const thisMonth = heroPool.filter(
  (v) => new Date(v.recorded_at).getUTCMonth() === now.getUTCMonth(),
);

let heroTier: "day" | "week" | "month" | "archive";
let featuredVideo: (typeof heroPool)[number] | null;
if (onThisDay.length) {
  featuredVideo = onThisDay[0];
  heroTier = "day";
} else if (thisWeek.length) {
  featuredVideo = pickDaily(thisWeek);
  heroTier = "week";
} else if (thisMonth.length) {
  featuredVideo = pickDaily(thisMonth);
  heroTier = "month";
} else {
  featuredVideo = pickDaily(heroPool);
  heroTier = "archive";
}

const featuredArtist = featuredVideo
  ? artistMap.get(featuredVideo.artist_id)
  : null;
const featuredSeries = featuredVideo
  ? seriesMap.get(featuredVideo.series_id)
  : null;
const featuredYear = featuredVideo
  ? new Date(featuredVideo.recorded_at).getUTCFullYear()
  : null;
const featuredEyebrow = !featuredVideo
  ? ""
  : heroTier === "day"
    ? `On this day in ${featuredYear}`
    : heroTier === "week"
      ? `Around this time in ${featuredYear}`
      : heroTier === "month"
        ? `This month in ${featuredYear}`
        : "From the archive";

// Videos sorted by views (most-watched first) for series sections
const videosBySeriesId = new Map<number, typeof allVideos>();
for (const v of allVideos) {
  if (!videosBySeriesId.has(v.series_id)) videosBySeriesId.set(v.series_id, []);
  videosBySeriesId.get(v.series_id)!.push(v);
}
for (const [, vids] of videosBySeriesId) {
  vids.sort((a, b) => b.views - a.views);
}

// Distinct years for browse strip (desc)
const distinctYears = [...new Set(years)].sort((a, b) => b - a);

// All tags for browse strip
const allTags = await db.select().from(tag);
const allVideoTags = await db.select().from(videoTag);
const tagVideoCounts = new Map<number, number>();
for (const vt of allVideoTags) {
  tagVideoCounts.set(vt.tag_id, (tagVideoCounts.get(vt.tag_id) ?? 0) + 1);
}
// Only show tags that have at least one published video
const publishedVideoIds = new Set(allVideos.map((v) => v.id));
const tagPublishedCounts = new Map<number, number>();
for (const vt of allVideoTags) {
  if (publishedVideoIds.has(vt.video_id)) {
    tagPublishedCounts.set(
      vt.tag_id,
      (tagPublishedCounts.get(vt.tag_id) ?? 0) + 1,
    );
  }
}
const activeTags = allTags
  .filter((t) => (tagPublishedCounts.get(t.id) ?? 0) > 0)
  .sort((a, b) => a.name.localeCompare(b.name));

function formatDate(d: Date) {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(d);
}
---

<Layout
  title="If You Make It — DIY Punk Video Archive"
  description={`DIY punk videos, sessions, and live recordings from ${minYear}–2014.`}
>
  <h1 class="visually-hidden">If You Make It video archive</h1>

  {
    featuredVideo && featuredArtist && featuredSeries && (
      <section
        class="featured"
        aria-label={featuredEyebrow}
        data-series={featuredSeries.slug}
      >
        <div class="featured-stage">
          <div class="featured-player">
            <VideoEmbed
              provider={
                featuredVideo.provider as
                  | "youtube"
                  | "vimeo"
                  | "dailymotion"
                  | "flash"
              }
              providerId={featuredVideo.provider_id}
              title={featuredVideo.title}
              thumbnail={getLocalThumb(featuredVideo.slug)}
            />
          </div>
        </div>
        <div class="container featured-meta">
          <p class="featured-eyebrow">{featuredEyebrow}</p>
          <h2 class="featured-artist">
            <a href={`/artists/${featuredArtist.slug}/`}>
              {featuredArtist.name}
            </a>
          </h2>
          <h3 class="featured-song">
            <a href={getVideoUrl(featuredVideo, featuredArtist)}>
              &ldquo;{featuredVideo.title}&rdquo;
            </a>
          </h3>
          <p class="meta-line featured-when">
            {featuredSeries.title} &mdash;{" "}
            {formatDate(new Date(featuredVideo.recorded_at))}
          </p>
          {featuredVideo.description && (
            <div
              class="featured-description"
              set:html={renderMarkdown(featuredVideo.description)}
            />
          )}
        </div>
      </section>
    )
  }

  <section class="about container" aria-label="About the archive">
    <p class="about-blurb">
      Dave Garwacke started If You Make It in New Paltz, NY and followed the
      couch to Brooklyn: bands passing through would sit down and play a song
      or two on a pink couch. From {minYear} to 2014 it grew into an archive of
      acoustic sessions, basement shows, and music videos from the DIY punk world.
      Hop Along, Waxahatchee, Tigers Jaw, The Bouncing Souls, and a couple hundred
      friends.
      <a class="about-link" href="/about/">Read the full story&nbsp;→</a>
    </p>
    <ul class="about-stats">
      <li>
        <strong>{totalVideos}</strong>
        <span>videos</span>
      </li>
      <li>
        <strong>{totalArtists}</strong>
        <span>artists</span>
      </li>
      <li>
        <strong>{totalYears}</strong>
        <span>years</span>
      </li>
      {
        totalViews > 0 && (
          <li>
            <strong>{formattedViews}</strong>
            <span>views</span>
          </li>
        )
      }
    </ul>
    <a class="about-numbers-link" href="/stats/"
      >See the full breakdown&nbsp;→</a
    >
  </section>

  {
    allSeries.map((s) => {
      const seriesVideos = (videosBySeriesId.get(s.id) ?? []).slice(0, cap);
      if (seriesVideos.length === 0) return null;
      return (
        <section class="series-section container" data-series={s.slug}>
          <SectionHeading
            title={s.title}
            href={`/${s.slug}/`}
            count={videosBySeriesId.get(s.id)?.length ?? 0}
          />
          <div class="grid-videos">
            {seriesVideos.map((v) => {
              const a = artistMap.get(v.artist_id);
              return (
                <VideoCard
                  title={v.title}
                  href={getVideoUrl(v, a!)}
                  artistName={a?.name ?? ""}
                  seriesTitle={s.title}
                  seriesSlug={s.slug}
                  recordedAt={new Date(v.recorded_at)}
                  provider={
                    v.provider as "youtube" | "vimeo" | "dailymotion" | "flash"
                  }
                  providerId={v.provider_id}
                  thumbnailSlug={v.slug}
                />
              );
            })}
          </div>
        </section>
      );
    })
  }

  <section class="browse-strip container">
    <SectionHeading title="Browse by Year" href="/years/" />
    <div class="chip-row">
      {
        distinctYears.map((y) => (
          <a class="tag-chip" href={`/years/${y}/`}>
            {y}
          </a>
        ))
      }
    </div>
  </section>

  {
    activeTags.length > 0 && (
      <section class="browse-strip container">
        <SectionHeading title="Browse by Tag" href="/tags/" />
        <div class="chip-row">
          {activeTags.map((t) => (
            <a class="tag-chip" href={`/tags/${t.slug}/`}>
              {t.name}
            </a>
          ))}
        </div>
      </section>
    )
  }
</Layout>

<style>
  /* ---------- the screening room ---------- */
  /* The stage fills the first screen: full-bleed true black sized to the
     viewport (minus the header), video as large as the height allows,
     title card below the fold. */
  .featured {
    padding: 0;
  }
  .featured-stage {
    /* Approximate header height; bumped for the two-row mobile header. */
    --stage-offset: 3.75rem;
    --stage-pad: clamp(1rem, 3vh, 2.5rem);
    display: grid;
    place-items: center;
    /* The room is black; the screen is the light source — a soft orchid
       bloom radiates from behind the player. */
    background:
      radial-gradient(
        ellipse 62% 58% at 50% 52%,
        rgba(215, 136, 232, 0.12),
        rgba(167, 139, 250, 0.05) 55%,
        transparent 75%
      ),
      #000;
    /* Fill the viewport when the video can use the height; when width is
       the limiting factor (tall/narrow screens), hug the video instead of
       leaving an empty black room. */
    min-height: min(
      calc(100vh - var(--stage-offset)),
      calc((100vw - 2rem) * 9 / 16 + 2 * var(--stage-pad))
    );
    min-height: min(
      calc(100svh - var(--stage-offset)),
      calc((100vw - 2rem) * 9 / 16 + 2 * var(--stage-pad))
    );
    padding: var(--stage-pad) clamp(1rem, 3vw, 2rem);
  }
  .featured-player {
    /* 16:9, as big as the stage height permits, edge-capped by width. */
    width: min(
      100%,
      calc((100vh - var(--stage-offset) - 2 * var(--stage-pad)) * 16 / 9),
      calc((100svh - var(--stage-offset) - 2 * var(--stage-pad)) * 16 / 9)
    );
    max-width: 1720px;
    margin-inline: auto;
  }
  .featured-player :global(.embed) {
    box-shadow: var(--tv-glow);
  }
  @media (max-width: 560px) {
    .featured-stage {
      --stage-offset: 7rem;
    }
  }

  /* ---------- about: the pitch, then the credits band ---------- */
  .about {
    padding-block: clamp(3rem, 8vw, 5.5rem);
    animation: slap-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards 0.25s;
  }
  /* Short copy, big type. */
  .about-blurb {
    margin: 0 0 clamp(2.5rem, 6vw, 4rem);
    font-size: clamp(1.25rem, 2.2vw, 1.6rem);
    line-height: 1.5;
    max-width: 52ch;
  }
  .about-link {
    margin-inline-start: 0.35em;
    font-family: var(--font-mono);
    font-size: 0.6em;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-ink);
    text-decoration: underline;
    text-decoration-thickness: 2px;
    text-underline-offset: 4px;
    white-space: nowrap;
  }
  .about-link:hover {
    color: var(--color-pink-deep);
  }
  /* The credits band: four big figures with hairline rules between,
     each in a run of the house colors. */
  .about-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    border-block: 1px solid var(--color-line);
  }
  .about-stats li {
    padding: clamp(1.5rem, 3.5vw, 2.5rem) 1rem;
    text-align: center;
    border-left: 1px solid var(--color-line);
    animation: stamp-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .about-stats li:first-child {
    border-left: 0;
  }
  .about-stats li:nth-child(1) {
    animation-delay: 0.35s;
  }
  .about-stats li:nth-child(2) {
    animation-delay: 0.45s;
  }
  .about-stats li:nth-child(3) {
    animation-delay: 0.55s;
  }
  .about-stats li:nth-child(4) {
    animation-delay: 0.65s;
  }
  .about-stats strong {
    display: block;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(2.6rem, 6vw, 4rem);
    line-height: 1;
  }
  .about-stats li:nth-child(1) strong {
    color: var(--color-pink);
  }
  .about-stats li:nth-child(2) strong {
    color: var(--color-blue);
  }
  .about-stats li:nth-child(3) strong {
    color: var(--color-ink);
  }
  .about-stats li:nth-child(4) strong {
    color: var(--color-pink-deep);
  }
  .about-stats span {
    display: block;
    margin-top: 0.7rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.74rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--color-muted);
  }
  .about-numbers-link {
    display: inline-block;
    margin-top: clamp(1.5rem, 3.5vw, 2.25rem);
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-muted);
    text-decoration: none;
    transition: color 0.12s ease;
    animation: stamp-in 0.45s cubic-bezier(0.22, 1, 0.36, 1) backwards 0.75s;
  }
  .about-numbers-link:hover {
    color: var(--color-pink-deep);
  }
  /* The title card: centered, big, crisp. */
  .featured-meta {
    padding-block: clamp(1.75rem, 4vw, 3rem) 0.5rem;
    text-align: center;
    animation: stamp-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards 0.15s;
  }
  .featured-eyebrow {
    margin: 0 0 1rem;
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.22em;
    color: var(--accent-text, var(--color-pink-deep));
  }
  .featured-artist {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 4.5rem);
    line-height: 0.98;
    margin: 0 0 0.5rem;
  }
  .featured-artist a,
  .featured-song a {
    color: inherit;
    text-decoration: none;
    transition: color 0.12s ease;
  }
  .featured-artist a:hover,
  .featured-song a:hover {
    color: var(--accent-text, var(--color-pink-deep));
  }
  .featured-song {
    margin: 0 0 0.9rem;
    font-family: var(--font-body);
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    font-size: clamp(1.2rem, 2.2vw, 1.6rem);
    line-height: 1.25;
    color: var(--color-ink);
  }
  .featured-when {
    margin: 0;
  }
  /* Short blurbs get room to speak. */
  .featured-description {
    margin: 1.5rem auto 0;
    max-width: 52ch;
    font-size: clamp(1.1rem, 1.7vw, 1.3rem);
    line-height: 1.55;
  }
  .featured-description :global(p) {
    margin-block: 0 0.85rem;
  }
  .featured-description :global(p:last-child) {
    margin-block-end: 0;
  }

  .series-section,
  .browse-strip {
    padding-block: clamp(2.5rem, 6vw, 4rem);
    border-top: var(--border);
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-block-start: 0.75rem;
  }

  /* Mobile: a roomy 2×2 credits grid with internal hairlines. */
  @media (max-width: 640px) {
    .about-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    .about-stats li {
      padding: 1.75rem 0.75rem;
    }
    .about-stats li:nth-child(odd) {
      border-left: 0;
    }
    .about-stats li:nth-child(n + 3) {
      border-top: 1px solid var(--color-line);
    }
    .about-stats strong {
      font-size: clamp(2.4rem, 11vw, 3rem);
    }
  }
</style>
