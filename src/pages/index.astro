---
import { db, eq, video, artist, series, tag, videoTag } from "astro:db";
import Layout from "../layouts/Layout.astro";
import VideoCard from "../components/VideoCard.astro";
import VideoEmbed from "../components/VideoEmbed.astro";
import SectionHeading from "../components/SectionHeading.astro";
import { getLocalThumb } from "../lib/thumbs";
import { getVideoUrl } from "../lib/video-url";

// Fetch all published series ordered by sort
const allSeries = await db
  .select()
  .from(series)
  .where(eq(series.publish, 1));
allSeries.sort((a, b) => a.sort - b.sort);

// Fetch all published videos with artist and series info
const allVideos = await db
  .select()
  .from(video)
  .where(eq(video.publish, 1));

const allArtists = await db.select().from(artist);
const artistMap = new Map(allArtists.map((a) => [a.id, a]));
const seriesMap = new Map(allSeries.map((s) => [s.id, s]));

// Stats
const totalVideos = allVideos.length;
const uniqueArtistIds = new Set(allVideos.map((v) => v.artist_id));
const totalArtists = uniqueArtistIds.size;
const years = allVideos.map((v) => new Date(v.recorded_at).getUTCFullYear());
const minYear = Math.min(...years);
const maxYear = Math.max(...years);
const totalYears = maxYear - minYear + 1;
const cap = 6

const totalViews = allVideos.reduce((sum, v) => sum + v.views, 0);
const formattedViews = new Intl.NumberFormat("en-US", {
  notation: "compact",
  maximumFractionDigits: 1,
}).format(totalViews);

// Featured video: featured=1, most recent
const featuredVideos = allVideos
  .filter((v) => v.featured === 1)
  .sort((a, b) => new Date(b.recorded_at).getTime() - new Date(a.recorded_at).getTime());
const featuredVideo = featuredVideos[0] ?? null;
const featuredArtist = featuredVideo ? artistMap.get(featuredVideo.artist_id) : null;
const featuredSeries = featuredVideo ? seriesMap.get(featuredVideo.series_id) : null;

// Videos sorted by views (most-watched first) for series sections
const videosBySeriesId = new Map<number, typeof allVideos>();
for (const v of allVideos) {
  if (!videosBySeriesId.has(v.series_id)) videosBySeriesId.set(v.series_id, []);
  videosBySeriesId.get(v.series_id)!.push(v);
}
for (const [, vids] of videosBySeriesId) {
  vids.sort((a, b) => b.views - a.views);
}

// Distinct years for browse strip (desc)
const distinctYears = [...new Set(years)].sort((a, b) => b - a);

// All tags for browse strip
const allTags = await db.select().from(tag);
const allVideoTags = await db.select().from(videoTag);
const tagVideoCounts = new Map<number, number>();
for (const vt of allVideoTags) {
  tagVideoCounts.set(vt.tag_id, (tagVideoCounts.get(vt.tag_id) ?? 0) + 1);
}
// Only show tags that have at least one published video
const publishedVideoIds = new Set(allVideos.map((v) => v.id));
const tagPublishedCounts = new Map<number, number>();
for (const vt of allVideoTags) {
  if (publishedVideoIds.has(vt.video_id)) {
    tagPublishedCounts.set(vt.tag_id, (tagPublishedCounts.get(vt.tag_id) ?? 0) + 1);
  }
}
const activeTags = allTags
  .filter((t) => (tagPublishedCounts.get(t.id) ?? 0) > 0)
  .sort((a, b) => a.name.localeCompare(b.name));

// Tape marquee copy — decorative, duplicated for the infinite loop.
const tapePhrases = [
  "Long live DIY",
  "Bands on a pink couch since 2007",
  `${totalVideos} videos`,
  `${totalArtists} artists`,
  "No ads · No algorithm",
  `Est. ${minYear}–${maxYear}`,
];

function formatDate(d: Date) {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
    timeZone: "UTC",
  }).format(d);
}
---

<Layout title="If You Make It — DIY Punk Video Archive" description={`DIY punk videos, sessions, and live recordings from ${minYear}–${maxYear}.`}>

  <section class="hero container" aria-labelledby="archive-heading">
    <h1 class="visually-hidden" id="archive-heading">If You Make It video archive</h1>
    <ul class="hero-stats">
      <li><strong>{totalVideos}</strong> videos</li>
      <li><strong>{totalArtists}</strong> artists</li>
      <li><strong>{totalYears}</strong> years</li>
      {totalViews > 0 && <li><strong>{formattedViews}</strong> views</li>}
    </ul>
  </section>

  <div class="tape" aria-hidden="true">
    <div class="tape__track">
      {[0, 1].map(() => (
        <span class="tape__run">
          {tapePhrases.map((phrase) => (
            <>
              <span class="tape__phrase">{phrase}</span>
              <span class="tape__star">★</span>
            </>
          ))}
        </span>
      ))}
    </div>
  </div>

  {featuredVideo && featuredArtist && featuredSeries && (
    <section class="featured container">
      <SectionHeading title="Featured" />
      <div class="featured-inner" data-series={featuredSeries.slug}>
        <VideoEmbed provider={featuredVideo.provider as "youtube" | "vimeo" | "dailymotion" | "flash"} providerId={featuredVideo.provider_id} title={featuredVideo.title} thumbnail={getLocalThumb(featuredVideo.slug)} />
        <div class="featured-meta">
          <h2 class="featured-artist">
            <a href={`/artists/${featuredArtist.slug}/`}>{featuredArtist.name}</a>
          </h2>
          <h3 class="featured-song">
            <a href={getVideoUrl(featuredVideo, featuredArtist)}>&ldquo;{featuredVideo.title}&rdquo;</a>
          </h3>
          <p class="meta-line">{featuredSeries.title} &mdash; {formatDate(new Date(featuredVideo.recorded_at))}</p>
          {featuredVideo.description && (
            <div class="featured-description" set:html={featuredVideo.description} />
          )}
        </div>
      </div>
    </section>
  )}

  {allSeries.map((s) => {
    const seriesVideos = (videosBySeriesId.get(s.id) ?? []).slice(0, cap);
    if (seriesVideos.length === 0) return null;
    return (
      <section class="series-section container" data-series={s.slug}>
        <SectionHeading title={s.title} href={`/${s.slug}/`} count={videosBySeriesId.get(s.id)?.length ?? 0} />
        <div class="grid-videos">
          {seriesVideos.map((v) => {
            const a = artistMap.get(v.artist_id);
            return (
              <VideoCard
                title={v.title}
                href={getVideoUrl(v, a!)}
                artistName={a?.name ?? ""}
                seriesTitle={s.title}
                seriesSlug={s.slug}
                recordedAt={new Date(v.recorded_at)}
                provider={v.provider as "youtube" | "vimeo" | "dailymotion" | "flash"}
                providerId={v.provider_id}
                thumbnailSlug={v.slug}
              />
            );
          })}
        </div>
      </section>
    );
  })}

  <section class="browse-strip container">
    <SectionHeading title="Browse by Year" href="/years/" />
    <div class="chip-row">
      {distinctYears.map((y) => (
        <a class="tag-chip" href={`/years/${y}/`}>{y}</a>
      ))}
    </div>
  </section>

  {activeTags.length > 0 && (
    <section class="browse-strip container">
      <SectionHeading title="Browse by Tag" href="/tags/" />
      <div class="chip-row">
        {activeTags.map((t) => (
          <a class="tag-chip" href={`/tags/${t.slug}/`}>{t.name}</a>
        ))}
      </div>
    </section>
  )}

</Layout>

<style>
  .hero {
    padding-block: 2rem;
    text-align: center;
  }
  .hero-stats {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(4, auto);
    gap: 1rem 2rem;
    justify-content: center;
    font-size: 0.95rem;
    color: var(--color-muted);
  }
  .hero-stats strong {
    color: var(--color-ink);
    font-family: var(--font-display);
    font-size: 1.4rem;
  }
  /* Stats slam down one by one like rubber stamps. */
  .hero-stats li {
    animation: stamp-in 0.4s cubic-bezier(0.22, 1, 0.36, 1) backwards;
  }
  .hero-stats li:nth-child(1) { animation-delay: 0.1s; }
  .hero-stats li:nth-child(2) { animation-delay: 0.22s; }
  .hero-stats li:nth-child(3) { animation-delay: 0.34s; }
  .hero-stats li:nth-child(4) { animation-delay: 0.46s; }

  /* ---------- tape marquee ---------- */
  /* A strip of gaffer tape slapped across the page, scrolling forever.
     Slightly oversized + rotated so the torn-off ends bleed offscreen. */
  .tape {
    width: 104%;
    margin-inline-start: -2%;
    transform: rotate(-1.1deg);
    background: var(--color-ink);
    border-block: var(--border-thin);
    box-shadow: 0 3px 0 rgba(22, 18, 26, 0.25);
    overflow: hidden;
    user-select: none;
  }
  .tape__track {
    display: flex;
    width: max-content;
    animation: tape-scroll 32s linear infinite;
  }
  .tape:hover .tape__track {
    animation-play-state: paused;
  }
  .tape__run {
    display: flex;
    align-items: center;
    flex: none;
    padding-block: 0.55rem;
  }
  .tape__phrase {
    font-family: var(--font-display);
    text-transform: uppercase;
    font-size: 0.82rem;
    letter-spacing: 0.06em;
    line-height: 1;
    color: var(--color-paper);
    white-space: nowrap;
  }
  .tape__star {
    color: var(--color-pink);
    font-size: 0.8rem;
    line-height: 1;
    padding-inline: 0.9em;
  }
  @keyframes tape-scroll {
    to {
      transform: translateX(-50%);
    }
  }

  .featured-inner {
    display: grid;
    grid-template-columns: minmax(0, 2fr) minmax(16rem, 1fr);
    align-items: stretch;
    border: var(--border);
    box-shadow: var(--shadow-hard);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-paper);
  }
  .featured {
    padding-block-end: 2rem;
  }
  .featured-inner {
    animation: slap-in 0.5s cubic-bezier(0.22, 1, 0.36, 1) backwards 0.18s;
  }
  .featured-inner :global(.embed) {
    height: 100%;
    border: 0;
    border-radius: 0;
    box-shadow: none;
  }
  .featured-meta {
    padding: clamp(1.25rem, 2.5vw, 2rem);
    border-left: var(--border);
  }
  .featured-artist {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 2.5vw, 2.4rem);
    line-height: 1;
    margin: 0 0 0.65rem;
  }
  .featured-artist a,
  .featured-song a {
    color: inherit;
    text-decoration: none;
  }
  .featured-artist a:hover,
  .featured-song a:hover {
    color: var(--accent, var(--color-pink));
  }
  .featured-song {
    margin: 0 0 1rem;
    font-family: var(--font-body);
    font-size: clamp(1.05rem, 1.5vw, 1.35rem);
    line-height: 1.2;
    color: var(--accent-text, var(--color-pink-deep));
  }
  .featured-description {
    margin-block-start: 1.25rem;
    font-size: 0.9rem;
  }
  .featured-description :global(p) {
    margin-block: 0 0.85rem;
  }
  .featured-description :global(p:last-child) {
    margin-block-end: 0;
  }

  .series-section,
  .browse-strip {
    padding-block: 2rem;
    border-top: var(--border);
  }
  .featured + .series-section {
    border-top: 0;
  }

  .chip-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-block-start: 0.75rem;
  }

  @media (max-width: 520px) {
    .hero {
      padding-block: 1.5rem;
    }
    .hero-stats {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }
  @media (max-width: 820px) {
    .featured-inner {
      grid-template-columns: 1fr;
    }
    .featured-inner :global(.embed) {
      height: auto;
    }
    .featured-meta {
      border-top: var(--border);
      border-left: 0;
    }
  }
</style>
